---
import '@/styles/tokens.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Stand — Build your own thing. For Real.',
  description = 'Stand is where kids create, launch, and grow real businesses. Brand studio, product lab, storefront, money math — the modern lemonade stand for the next generation.',
  ogImage = '/og-image.png',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://standkids.com');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#faf3d6" />
    <link rel="canonical" href={canonical.toString()} />

    <link rel="icon" type="image/svg+xml" href="/brand/logo.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Stand" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:image" content={new URL(ogImage, canonical).toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, canonical).toString()} />

    <link rel="preload" href="/fonts/AUTHENTICSans-90.otf" as="font" type="font/otf" crossorigin />
    <link rel="preload" href="/fonts/AUTHENTICSans-130.otf" as="font" type="font/otf" crossorigin />
    <link rel="preload" href="/fonts/EditorialNew-Light.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/fonts/PiePie-Regular.ttf" as="font" type="font/ttf" crossorigin />

    <title>{title}</title>
  </head>
  <body>
    <slot />

    <script>
      // Cross-domain attribution hand-off. The marketing site (standkids.com)
      // and the app (app.standkids.com) are separate origins, so the app's
      // first-party attribution cookie can't be read here — the URL is the only
      // carrier across the hop. Forward any incoming UTM / promo params onto
      // every app CTA so the app's AttributionCapture picks them up. When a
      // visitor arrived with no UTMs, tag the link as marketing-site-originated
      // so direct standkids.com -> app conversions are still attributable
      // instead of looking like direct traffic.
      (() => {
        const FORWARD_KEYS = [
          "utm_source",
          "utm_medium",
          "utm_campaign",
          "utm_content",
          "utm_term",
          "promotion_code",
          "code",
        ];
        const incoming = new URLSearchParams(window.location.search);
        const carried = new URLSearchParams();
        for (const key of FORWARD_KEYS) {
          const v = incoming.get(key);
          if (v) carried.set(key, v);
        }

        // First-touch default: an un-tagged marketing-site visit still gets
        // attributed to the site (never overrides a real campaign's UTMs).
        const hasUtm = [...carried.keys()].some((k) => k.startsWith("utm_"));
        if (!hasUtm) {
          carried.set("utm_source", "standkids-site");
          carried.set("utm_medium", "referral");
        }
        if ([...carried].length === 0) return;

        for (const a of document.querySelectorAll('a[href*="app.standkids.com"]')) {
          const href = a.getAttribute("href");
          // Never rewrite API/form endpoints (e.g. /api/waitlist) — only nav CTAs.
          if (!href || href.includes("/api/")) continue;
          let url;
          try {
            url = new URL(href, window.location.origin);
          } catch {
            continue;
          }
          // Incoming params win, but don't clobber a value the link already pins.
          for (const [k, v] of carried) {
            if (!url.searchParams.has(k)) url.searchParams.set(k, v);
          }
          a.setAttribute("href", url.toString());
        }
      })();
    </script>
  </body>
</html>

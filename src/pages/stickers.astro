---
import Layout from "@/layouts/Layout.astro";
import Footer from "@/components/Footer.astro";
import "@/styles/lp.css";

// STICKERS — the entry vertical. Parent-facing landing page.
// Receipt captured live from the app's Money Math lesson (2026-06-11): sticker
// 3-pack $15 default, production $5.67 (Fyul $1.75/unit x1.08 x3), shipping $1.99,
// card $0.73 -> keeps $6.60 (44%). No Stand fee — removed app-wide in STA-774.
// Parent model: a parental CONSENT gate (ParentGate) before the shop publishes.
// There is NO per-sale/per-transaction approval in the app — copy reflects that.
const APP = "https://app.standkids.com";

const journey = [
  { step: "01 — Name it", tool: "ideas-tent", name: "ideas tent",
    do: "Brainstorm and pick their sticker brand's name with the coach.",
    learn: "What makes a name memorable — and how real brands choose theirs.",
    proof: "“Nike is the goddess of victory. Apple is simple and friendly. What feeling should your name give?”" },
  { step: "02 — Brand it", tool: "brand-studio", name: "brand studio",
    do: "Pick a vibe, a color story, and refine a logo until it's theirs.",
    learn: "A brand is a deliberate system — and good designers ask for changes.",
    proof: "“Want changes? Tell us what to tweak.”" },
  { step: "03 — Design it", tool: "product-lab", name: "product lab",
    do: "Turn their drawing into a single sticker or a whole themed sheet.",
    learn: "What it takes to make art print-ready: bold lines, clean edges, real vinyl.",
    proof: "The coach teaches what kiss-cut vinyl can and can't do — a real production constraint." },
  { step: "04 — Price it", tool: "money", name: "money",
    do: "Set a price and watch the real margin update live.",
    learn: "Margin, costs, and fees — and that a price has to clear cost.",
    proof: "Subtracts real production, shipping, and the real card fee — Stand takes no cut. Underprice, and the screen shows a loss." },
  { step: "05 — Promote it", tool: "marketing", name: "marketing",
    do: "Write a tagline, pick who to tell, and make a clear ask.",
    learn: "A product needs an audience — and a message that sounds like them.",
    proof: "Taught with the greats: “Just Do It.” “Think Different.”" },
  { step: "06 — Sell it", tool: "storefront", name: "storefront",
    do: "Open a real shop, share the link, and ship a real order.",
    learn: "The loop closes: their sticker is on someone else's water bottle.",
    proof: "A parent gives consent before the shop can go live." },
];

const useCases = [
  { wide: true, h: "Laptop, tablet & water-bottle decor", p: "Every Hydro Flask at school is covered in stickers. Your kid designs the ones their friends actually want — a vibe, a saying, a mini character — and the pack lands on a dozen bottles by Friday.", who: "Who buys: classmates, teammates, siblings" },
  { h: "Book club & fandom packs", p: "A stack-of-books sticker, a reading cat, an inside joke from the series — sold to club members and the kids just as deep into the same game or show.", who: "Who buys: club families & fellow fans" },
  { h: "Locker & binder back-to-school", p: "Name tags, label stickers, and little motifs for lockers, binders, and planners — a coordinated set, sold right as the year starts.", who: "Who buys: classmates & supply-stocking parents" },
  { h: "Party favors & classroom rewards", p: "A birthday batch with the birthday kid's name, or a “great job” set for the teacher. One adult buyer, one bigger order — the simplest sale of all.", who: "Who buys: party parents & teachers" },
  { h: "A give-back drop", p: "An animal pack for the local shelter, with part of every sale earmarked to donate. The money lesson literally ends on reinvest, save, spend, or donate.", who: "Who buys: neighbors & cause-minded families" },
];

const faqs = [
  { q: "Is this real money, or play money?", a: "It's real. Your kid's shop takes real Stripe payments and the stickers really print and ship to the buyer. And nothing goes live until a parent gives consent — a built-in gate before the shop opens. The Money step also teaches honest math: it subtracts real costs and fees and will even show a loss if the price is too low." },
  { q: "Is it safe for my kid?", a: "Stand is built for ages 6 to 16 and is COPPA-compliant by design. The AI coach is disclosed as an AI, all generated art is filtered for age-appropriate content and moderated, no personal data is shared or sold, and there are no ads. A parent consents before the shop goes live, and there's a parent dashboard for oversight." },
  { q: "What does the STANDSUMMER code actually get me?", a: "Full access to Stand, free, for the whole summer — through September 1. Your kid can run the entire journey, open a real shop, and make real sales. You pay nothing unless you choose to continue after September 1." },
  { q: "Will my kid actually be able to sell anything?", a: "We never guarantee sales — that wouldn't be honest. What we can promise is a real, shareable shop and the easiest, lowest-priced product to say yes to, plus built-in audiences your kid already has: classmates, clubs, teammates, and family. Outcomes are real opportunities, not promises." },
  { q: "How much of my time does this take?", a: "Not much. The coach narrates every step and answers your kid's questions, so they can largely self-drive. You step in at the moment that matters — giving consent at the gate before the shop goes live — and can watch progress from the parent dashboard." },
  { q: "Couldn't I just help them make stickers myself?", a: "You could. But Stand gives your kid structure, real design tools, an AI coach, honest money math, and an actual storefront that keeps them going long after day one — plus we handle printing and shipping. The goal isn't a perfect business at age nine. It's the habit of building." },
  { q: "Do I have to buy a bunch of stickers up front?", a: "No. It's print-on-demand — stickers are made only when someone buys. No inventory, no upfront product cost, no box of unsold stickers in the closet. You're not financing a business; you're backing a kid." },
];

const Check = `<svg width="20" height="20" viewBox="0 0 20 20" aria-hidden="true"><circle cx="10" cy="10" r="9" fill="#00623b"/><path d="M6 10.5l2.5 2.5L14 7.5" stroke="#faf3d6" stroke-width="2" fill="none" stroke-linecap="round"/></svg>`;
---

<Layout
  title="Stand — Start a real sticker business. For Real."
  description="Your kid turns a drawing into a real vinyl sticker pack, opens a real online shop, and we print and ship every order. Real. Supervised. And theirs. Guided by an AI coach, with a parent consent gate before it goes live."
>
  <div class="lp">
    <div class="lp-promo">Summer on us — code <span class="code">STANDSUMMER</span> gets free access through September 1</div>

    <!-- HEADER -->
    <header class="lp-head">
      <a href="https://standkids.com" aria-label="Stand"><img src="/brand/logo.svg" alt="Stand" height="30" /></a>
      <div class="lp-head-right">
        <a href={APP} class="lp-login">Already have an account? <strong>LOG IN</strong></a>
        <a href={APP} class="lp-btn lp-head-cta">Start Building <span aria-hidden="true">&rarr;</span></a>
      </div>
    </header>

    <!-- HERO -->
    <section class="lp-hero">
      <div class="lp-wrap">
        <div>
          <p class="lp-eyebrow">A real sticker business — ages 6 to 16</p>
          <h1>They design the stickers. We ship the real thing. <img class="lp-forreal-img" src="/brand/STAND_ForReal.svg" alt="For Real." /></h1>
          <p class="sub">Your kid turns a drawing into a real vinyl sticker pack, builds a real online shop, and we print and mail every order. A real first business — guided by an AI coach, and nothing goes live until a parent says yes.</p>
          <div class="cta-row">
            <a href={APP} class="lp-btn">Start your kid's sticker shop <span aria-hidden="true">&rarr;</span></a>
            <a href="#journey" class="lp-btn lp-btn--ghost">See how it works</a>
          </div>
          <p class="lp-cta-note">Free all summer with code STANDSUMMER — pay nothing until September 1.</p>
        </div>
        <div class="lp-hero-stage" aria-hidden="true">
          <div class="hero-blob"></div>
          <img class="hero-sticker" src="/brand/STAND_PNG_YellowSticker.webp" alt="" />
          <div class="hero-kicker">Designed entirely by a kid. Really.</div>
        </div>
      </div>
    </section>

    <!-- MARQUEE -->
    <div class="lp-marquee" aria-hidden="true">
      <div class="lp-marquee-inner">
        <span>Dream. Build. Grow. <em>&rarr;</em> Create your brand. <em>&rarr;</em> Design the stickers. <em>&rarr;</em> Set an honest price. <em>&rarr;</em> Open a real shop. <em>&rarr;</em> Make your first sale. <em>&rarr;</em></span>
        <span>Dream. Build. Grow. <em>&rarr;</em> Create your brand. <em>&rarr;</em> Design the stickers. <em>&rarr;</em> Set an honest price. <em>&rarr;</em> Open a real shop. <em>&rarr;</em> Make your first sale. <em>&rarr;</em></span>
      </div>
    </div>

    <!-- HOW IT WORKS -->
    <section class="lp-how lp-section">
      <div class="lp-wrap">
        <div class="lp-sec-head">
          <p class="lp-eyebrow">Kid-built, parent-cleared</p>
          <h2>They build it. You say yes. It ships.</h2>
        </div>
        <div class="lp-grid-3">
          <div class="lp-how-card"><div class="lp-how-num">1</div><h3>Your kid builds</h3><p>They name the brand, design the logo, turn their drawings into stickers, set the price, and write the pitch — guided step by step by a patient AI coach.</p></div>
          <div class="lp-how-card is-approve"><div class="lp-how-num">2</div><h3>A parent says yes</h3><p>Before the shop can go live, a parent has to give consent — a built-in gate. No ads, no data selling, and the AI coach is always disclosed as an AI.</p></div>
          <div class="lp-how-card"><div class="lp-how-num">3</div><h3>The real thing ships</h3><p>When a classmate's family or a teacher orders, the pack is actually printed — real kiss-cut vinyl — and mailed to their door.</p></div>
        </div>
      </div>
    </section>

    <!-- INSIDE STAND — real app screenshots -->
    <section class="lp-section lp-inside">
      <div class="lp-wrap">
        <div class="lp-sec-head">
          <p class="lp-eyebrow">Inside Stand</p>
          <h2>This is the actual software your kid uses.</h2>
          <p>Not a slideshow. A real, guided workspace — with an AI coach narrating every step, the whole business on one screen, and honest money math built in.</p>
        </div>
        <div class="lp-grid-3">
          <div>
            <div class="lp-shot"><img src="/app-screens/sticker-storefront.png" alt="The Stand workshop showing a kid's sticker business — name, logo, and product preview on one screen" loading="lazy" /></div>
            <p class="lp-shot-cap">The whole business on one screen</p>
          </div>
          <div>
            <div class="lp-shot"><img src="/app-screens/sticker-receipt.png" alt="Stand's Money Math lesson — the live sticker receipt: price, cost, shipping, card fee, and what the kid keeps" loading="lazy" /></div>
            <p class="lp-shot-cap">Real money math, built in</p>
          </div>
          <div>
            <div class="lp-shot"><img src="/app-screens/sticker-lab.png" alt="Stand's Sticker Design Lab — a kid's name and icon design on the real die-cut sticker surface" loading="lazy" /></div>
            <p class="lp-shot-cap">The Sticker Design Lab — what they design is what prints</p>
          </div>
        </div>
      </div>
    </section>

    <!-- LEARNING JOURNEY (carousel) -->
    <section id="journey" class="lp-section" style="background:var(--stand-white);border-top:2px solid var(--lp-ink);border-bottom:2px solid var(--lp-ink);">
      <div class="lp-wrap">
        <div class="lp-sec-head">
          <p class="lp-eyebrow">The Stand Toolbox</p>
          <h2>Six real skills, learned by doing each one.</h2>
          <p>Every tool in Stand teaches a skill by making your kid actually use it. No worksheets. No lectures. Just doing. Click through the six.</p>
        </div>
        <div class="lp-carousel" data-lp-carousel>
          <button class="lp-carousel-nav prev" type="button" aria-label="Previous tool">&#8249;</button>
          <button class="lp-carousel-nav next" type="button" aria-label="Next tool">&#8250;</button>
          <div class="lp-carousel-track">
            {journey.map((j) => (
              <article class="lp-jcard">
                <img class="tool" src={`/brand/icon-${j.tool}.png`} alt="" loading="lazy" />
                <div class="step">{j.step}</div>
                <h3>{j.name}</h3>
                <p class="row"><b>They do</b>{j.do}</p>
                <p class="row"><b>They learn</b>{j.learn}</p>
                <div class="proof">{j.proof}</div>
              </article>
            ))}
          </div>
        </div>
        <p class="lp-journey-close">From sketch to <span class="lp-forreal">sold.</span></p>
      </div>
    </section>

    <!-- WHAT THEY MAKE -->
    <section class="lp-products lp-section">
      <div class="lp-wrap">
        <div class="lp-sec-head">
          <p class="lp-eyebrow">Find your business — stickers &amp; art</p>
          <h2>Two real formats. What they design is what prints.</h2>
          <p>No pretend previews. The art your kid finishes in the Product Lab is the file a real printer runs when someone orders.</p>
        </div>
        <div class="lp-grid-2">
          <div class="lp-prod">
            <div class="lp-prod-visual contain" style="background:var(--stand-blue);"><img src="/brand/STAND_PNG_YellowSticker.webp" alt="A Stand kiss-cut vinyl sticker" /></div>
            <h3>Single Stickers</h3>
            <ul>
              <li>Individual kiss-cut vinyl stickers of their own art</li>
              <li>Generated logos get the white background stripped automatically — intentional, not a printout</li>
              <li>The cheapest product to make and the easiest first sale — classmates can afford it on allowance</li>
            </ul>
            <div class="lp-ships">Printed per order &middot; Really ships</div>
          </div>
          <div class="lp-prod">
            <div class="lp-photo-ph"><span>Real photo — a full sticker sheet with multiple kid designs, in hand (PRD &sect;10)</span></div>
            <h3>Sticker Sheets</h3>
            <ul>
              <li>Multiple designs on one sheet — a whole themed drop</li>
              <li>Perfect for packs: a book-club set, a fandom set, a team set</li>
              <li>Sheets sell better than singles — one design decision, many stickers</li>
            </ul>
            <div class="lp-ships">Printed per order &middot; Really ships</div>
          </div>
        </div>
      </div>
    </section>

    <!-- USE CASES -->
    <section class="lp-section">
      <div class="lp-wrap">
        <div class="lp-sec-head">
          <p class="lp-eyebrow">Picture your kid</p>
          <h2>Five ways a kid's sticker shop actually sells.</h2>
          <p>Kids already decorate everything they own. Yours becomes the source instead of the customer.</p>
        </div>
        <div class="lp-grid-3">
          {useCases.map((u) => (
            <div class={`lp-uc${u.wide ? " is-wide" : ""}`}><h3>{u.h}</h3><p>{u.p}</p><div class="who">{u.who}</div></div>
          ))}
        </div>
      </div>
    </section>

    <!-- MONEY -->
    <section class="lp-money lp-section" style="background:var(--stand-white);border-top:2px solid var(--lp-ink);border-bottom:2px solid var(--lp-ink);">
      <div class="lp-wrap">
        <div>
          <p class="lp-eyebrow">Money — the lesson parents love</p>
          <h2 style="font-size:40px;margin-top:14px;">Real numbers. A real lesson. No pretend profit.</h2>
          <p style="margin-top:16px;color:var(--lp-ink-70);font-size:18px;">When your kid sets a price, Stand shows the live math — real production and shipping costs and the real card-processing fee. Stand takes no cut of your kid's sales. If they price too low, the screen shows a loss — and they learn why.</p>
          <p class="lp-lesson">It teaches money. It never promises money. The lesson ends the way real money decisions do: reinvest, save, spend, or donate.</p>
        </div>
        <div class="lp-receipt" aria-label="Example margin receipt">
          <div class="r-title">One pack, sold — the live math</div>
          <div class="row"><span>Sticker 3-pack</span><span>$15.00</span></div>
          <div class="row"><span>Printing the real thing</span><span>&minus;$5.67</span></div>
          <div class="row"><span>Shipping</span><span>&minus;$1.99</span></div>
          <div class="row"><span>Card fee (2.9% + 30¢)</span><span>&minus;$0.73</span></div>
          <div class="row total"><span>Your kid keeps</span><span>$6.60</span></div>
          <p class="note">Real numbers — the app's default price and true costs (44% margin). Stand takes no cut.</p>
        </div>
      </div>
    </section>

    <!-- FOUNDER LETTER -->
    <section class="lp-section">
      <div class="lp-wrap">
        <div class="lp-letter-wrap lp-letter">
          <div class="lp-letter-photo lp-photo-ph"><span>Real photo — the founder (PRD &sect;10)</span></div>
          <div>
            <p class="lp-eyebrow">Why we built Stand</p>
            <h2>A real business — because pretend wasn't enough.</h2>
            <p class="lp-sample-tag" style="margin-bottom:14px;">Placeholder — replace with a real, signed founder letter</p>
            <p>[Founder letter — 4 to 6 sentences, first person. The origin: why a real shop that really ships beats a worksheet or an app that's secretly a game. The thing every kid should walk away with: the proof they can make a real thing and put it into the world.]</p>
            <p>[Close on the parent: you don't have to be an entrepreneur to raise one. Stand does the heavy lifting — the tools, the coach, the printing, the shipping. You just say yes.]</p>
            <p class="sig">— [Founder name]</p>
            <p class="sig-name">[Title], Stand Kids Inc</p>
          </div>
        </div>
      </div>
    </section>

    <!-- SOCIAL PROOF -->
    <section class="lp-proof lp-section">
      <div class="lp-wrap">
        <div class="lp-sec-head">
          <p class="lp-eyebrow">Real families</p>
          <h2>What parents say.</h2>
        </div>
        <div class="lp-grid-3">
          <div class="lp-tcard pink"><p>"Watching her take orders, handle her own money, and stay proud of something she built herself. That's the stuff you can't teach in a classroom."</p><div class="name">— Parent of Lily, age 12</div></div>
          <div class="lp-tcard mustard"><p>"I thought starting a business would be easy. Then I had to make decisions, set prices, and keep going when it got hard. STAND helped me figure it out."</p><div class="name">— Ryan, age 10</div></div>
          <div class="lp-tcard postit"><p>"He cared about every detail — the name, the logo, the product, the packaging. STAND turned his creativity into something structured."</p><div class="name">— Parent of Leo, 13</div></div>
        </div>
      </div>
    </section>

    <!-- TRUST -->
    <section class="lp-section">
      <div class="lp-wrap">
        <div class="lp-sec-head">
          <p class="lp-eyebrow">Safety &amp; trust</p>
          <h2>You don't have to be an entrepreneur to raise one.</h2>
          <p>Kids lead. You stay in control of what matters — and you never have to teach a thing you don't already know.</p>
        </div>
        <div class="lp-trust-grid is-single">
          <div>
            <div class="lp-check" set:html={Check + "<span>Nothing goes live until a parent gives consent — a built-in gate before the shop opens.</span>"}></div>
            <div class="lp-check" set:html={Check + "<span>COPPA compliant — no personal data shared or sold, and no ads, ever.</span>"}></div>
            <div class="lp-check" set:html={Check + "<span>Every image — generated or uploaded — is AI-moderated before it's used. If the check can't run, it's blocked.</span>"}></div>
            <div class="lp-check" set:html={Check + "<span>The AI coach is always disclosed as an AI — age-appropriate and moderated.</span>"}></div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="lp-faq lp-section">
      <div class="lp-wrap">
        <div class="lp-sec-head">
          <p class="lp-eyebrow">Questions parents actually ask</p>
          <h2>The honest answers.</h2>
        </div>
        {faqs.map((f) => (
          <details><summary>{f.q}</summary><p>{f.a}</p></details>
        ))}
      </div>
    </section>

    <!-- BECOMING A BUILDER -->
    <section class="lp-section" style="background:var(--stand-white);border-top:2px solid var(--lp-ink);">
      <div class="lp-wrap">
        <div class="lp-manifesto">
          <p class="lp-eyebrow">The long game</p>
          <h2>It's not a sticker business. It's a <span class="lp-forreal">builder.</span></h2>
          <p>The goal was never a perfect shop at age nine. It's a kid who learns, for real, that they can make something and put it into the world — and the quiet confidence to do it again. Built for them. And for you.</p>
        </div>
      </div>
    </section>

    <!-- PRICING + CLOSE -->
    <section class="lp-close lp-section" id="pricing">
      <div class="lp-wrap">
        <div class="lp-price">
          <div class="flag">Summer on us — code STANDSUMMER</div>
          <p class="lp-eyebrow" style="color:var(--lp-ink-55);">This summer, the whole thing is free</p>
          <div class="amount"><span class="strike">$99/yr</span>$0<small> until Sept 1</small></div>
          <p class="reframe">$99/yr after the summer — less than $2 a week.</p>
          <p style="color:var(--lp-ink-70);margin-top:10px;">Use code STANDSUMMER for full access all summer — the journey, the coach, the real shop, real orders. Pay only if you continue after September 1.</p>
          <ul>
            <li set:html={Check + "<span>The full six-step journey with the AI coach</span>"}></li>
            <li set:html={Check + "<span>A real, shareable shop — opened only after a parent consents</span>"}></li>
            <li set:html={Check + "<span>Printing and shipping, handled per order</span>"}></li>
            <li set:html={Check + "<span>The full parent dashboard for oversight</span>"}></li>
          </ul>
          <a href={APP} class="lp-btn" style="width:100%;justify-content:center;">Start your kid's sticker shop <span aria-hidden="true">&rarr;</span></a>
        </div>
        <h2>Stand by your kid — and turn their idea into something <span class="lp-forreal">real.</span></h2>
        <p class="sub">This summer, trying it costs nothing. After September 1, it's $99/yr — less than $2 a week.</p>
        <a href={APP} class="lp-btn">Start your kid's sticker shop <span aria-hidden="true">&rarr;</span></a>
        <p class="lp-cta-note">Free all summer with code STANDSUMMER. A parent consents before anything goes live.</p>
      </div>
    </section>

    <Footer />
  </div>
</Layout>

<script>
  // Click-through carousel for the learning-journey cards.
  document.querySelectorAll<HTMLElement>("[data-lp-carousel]").forEach((root) => {
    const track = root.querySelector<HTMLElement>(".lp-carousel-track");
    if (!track) return;
    const stepBy = () => {
      const card = track.querySelector<HTMLElement>(".lp-jcard");
      return card ? card.getBoundingClientRect().width + 22 : 360;
    };
    root.querySelector(".lp-carousel-nav.prev")?.addEventListener("click", () =>
      track.scrollBy({ left: -stepBy(), behavior: "smooth" })
    );
    root.querySelector(".lp-carousel-nav.next")?.addEventListener("click", () =>
      track.scrollBy({ left: stepBy(), behavior: "smooth" })
    );
  });
</script>

<style>
  .lp-head { display: flex; align-items: center; justify-content: space-between; padding: 18px 28px; max-width: var(--lp-maxw); margin: 0 auto; gap: 16px; }
  .lp-head-right { display: flex; align-items: center; gap: 18px; }
  .lp-login { font-family: var(--font-sans); font-size: 14px; color: var(--lp-ink); }
  .lp-login strong { color: var(--stand-red); text-decoration: underline; text-underline-offset: 3px; margin-left: 3px; }
  .lp-head-cta { font-size: 14px; padding: 10px 18px; box-shadow: var(--lp-shadow-chip); }

  .hero-blob { position: absolute; inset: 6% 8%; background: var(--stand-blue); border-radius: 46% 54% 52% 48% / 52% 46% 54% 48%; border: 2px solid var(--lp-ink); }
  .hero-sticker { position: relative; width: 66%; filter: drop-shadow(0 18px 22px rgba(35,33,32,0.25)); transform: rotate(-5deg); }
  .hero-kicker { position: absolute; bottom: 2%; left: 0; background: var(--stand-postit); border: 2px solid var(--lp-ink); border-radius: var(--lp-r-card); padding: 9px 16px; font-size: 14px; box-shadow: var(--lp-shadow-chip); transform: rotate(-3deg); }
  .lp-hero-stage { min-height: 380px; }

  @media (max-width: 900px) {
    .lp-head-cta { display: none; }
    .lp-hero-stage { min-height: 300px; margin-top: 20px; }
  }
</style>

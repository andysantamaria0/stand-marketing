---
import Layout from "@/layouts/Layout.astro";
import Footer from "@/components/Footer.astro";
import "@/styles/lp.css";

// APPAREL — the group / roster wedge. Parent-facing landing page.
// The apparel twin of stickers.astro: same structure, classes, and voice.
// Numbers verified against docs/vertical-marketing-feature-blocks.md §6 + the
// PFL/PFY unit-economics sheet. Crewneck $45 -> keeps ~$22.58 (50% margin);
// Receipts captured live from the app's Money Math lesson (2026-06-11):
// sweatshirt $45 -> keeps $23.33 (52%); hoodie $49 -> keeps $24.73 (50%). The app
// teaches a flat $5.99 shipping estimate for apparel. Fee stack: card 2.9%+30c
// only — no Stand fee (removed app-wide in STA-774).
// App screenshots in /public/app-screens captured from the live workshop.
// Parent model: a parental CONSENT gate (ParentGate) before the store publishes.
// There is NO per-sale/per-transaction approval in the app — copy reflects that.
const APP = "https://app.standkids.com";

const journey = [
  { step: "01 — Name it", tool: "ideas-tent", name: "ideas tent",
    do: "Brainstorm and pick their apparel brand's name with the coach.",
    learn: "What makes a name memorable — and how real brands choose theirs.",
    proof: "“Nike is the goddess of victory. Apple is simple and friendly. What feeling should your name give?”" },
  { step: "02 — Brand it", tool: "brand-studio", name: "brand studio",
    do: "Pick a vibe, a color story, and refine a logo until it's theirs.",
    learn: "A brand is a deliberate system — and good designers ask for changes.",
    proof: "“Want changes? Tell us what to tweak.”" },
  { step: "03 — Design it", tool: "product-lab", name: "product lab",
    do: "Design the actual hoodie or cap — colors, art, and placement.",
    learn: "A real production constraint: embroidery isn't a print.",
    proof: "“Embroidery is different from a regular print. Bold shapes and fewer colors look the best. Tiny details can get lost in the stitching.”" },
  { step: "04 — Price it", tool: "money", name: "money",
    do: "Set a price and watch the real margin update live.",
    learn: "Margin, costs, and fees — and that a price has to clear cost.",
    proof: "Subtracts real production, shipping, and the real card fee — Stand takes no cut. Underprice, and the screen shows a loss." },
  { step: "05 — Promote it", tool: "marketing", name: "marketing",
    do: "Write a tagline, pick who to tell, and make a clear ask.",
    learn: "A product needs an audience — and a message that sounds like them.",
    proof: "Taught with the greats: “Just Do It.” “Think Different.”" },
  { step: "06 — Sell it", tool: "storefront", name: "storefront",
    do: "Open a real shop, share the link, and ship a real order.",
    learn: "The loop closes: their hoodie is on a teammate's back.",
    proof: "A parent gives consent before the shop can go live." },
];

const useCases = [
  { wide: true, h: "The summer rec-league team", p: "A 10-year-old on the roster designs the cap and hoodie in team colors, opens the store, and the link goes in the group chat. Twelve families order their own sizes — nobody collects cash, nobody fronts a bulk order.", who: "Who buys: teammates' parents, grandparents, the coach" },
  { h: "The summer camp crew", p: "A “Camp 2026” crewneck and cap as the unofficial group merch. Bunkmates order keepsakes they'll actually wear home.", who: "Who buys: camp families wanting a memento" },
  { h: "The school club or spirit squad", p: "Robotics club, drama crew, student section — spirit hoodies designed by the kid who becomes the group's de facto merch person.", who: "Who buys: club members & their families" },
  { h: "The family reunion", p: "A matching family-name crewneck, ordered by aunts and cousins across the country and shipped to each household. No suitcase of shirts.", who: "Who buys: the whole extended family" },
  { h: "The neighborhood crew", p: "A block-party or backyard-club hoodie for the kids who are always together. One design, every household orders its own.", who: "Who buys: neighbor families" },
  { h: "The birthday-party squad", p: "The birthday kid designs a matching cap for the friend group as the party uniform and favor. Guests' parents order ahead from the link.", who: "Who buys: invited guests' parents" },
];

const faqs = [
  { q: "Is this real money, or play money?", a: "It's real. Your kid's store takes real Stripe payments and the apparel really prints, embroiders, and ships to the buyer. And nothing goes live until a parent gives consent — a built-in gate before the store opens. The Money step also teaches honest math: it subtracts real costs and fees and will even show a loss if the price is too low." },
  { q: "Is it safe for my kid?", a: "Stand is built for ages 6 to 16 and is COPPA-compliant by design. The AI coach is disclosed as an AI, all generated art is filtered for age-appropriate content and moderated, no personal data is shared or sold, and there are no ads. A parent consents before the store goes live, and there's a full parent dashboard for oversight." },
  { q: "Will I end up financing inventory?", a: "No. It's print-on-demand — a hoodie or cap is made only when someone buys it. No upfront product cost, no garage full of unsold gear, no leftover boxes. You're not financing a business; you're backing a kid." },
  { q: "What does the STANDSUMMER code actually get me?", a: "Full access to Stand, free, for the whole summer — through September 1. Perfect timing for the rec-league season, camp, or the reunion: your kid can design the gear, open the store, and outfit the whole group. You pay nothing unless you choose to continue after September 1." },
  { q: "How much of my time does this take?", a: "Not much. The coach narrates every step and answers your kid's questions, so they can largely self-drive. You step in at the moment that matters — giving consent at the gate before the store goes live — and watch progress from the parent dashboard." },
  { q: "Couldn't I just order team shirts myself?", a: "You could — and you'd be collecting sizes, fronting the bulk order, and chasing families for cash. Stand hands that whole project to your kid: they design it, everyone orders their own size from one link, and each piece is made per order. You just give consent at the gate before the store goes live." },
  { q: "Why apparel for a first business?", a: "Because every team, club, camp, and crew is a built-in customer list of families who all want the same thing — and apparel is the biggest billboard you can wear. Your kid becomes the group's merch person, learns the full build, and the audience is already there. We never promise sales — we give them a real, shareable store and a real reason for people to say yes." },
];

const Check = `<svg width="20" height="20" viewBox="0 0 20 20" aria-hidden="true"><circle cx="10" cy="10" r="9" fill="#00623b"/><path d="M6 10.5l2.5 2.5L14 7.5" stroke="#faf3d6" stroke-width="2" fill="none" stroke-linecap="round"/></svg>`;
---

<Layout
  title="Stand — Start a real apparel business. For Real."
  description="Your kid designs a real hoodie or crewneck, opens a real online store the whole team can order from, and we print and ship every order. Real. Supervised. And theirs. Guided by an AI coach, with a parent consent gate before it goes live."
>
  <div class="lp">
    <div class="lp-promo">Summer on us — code <span class="code">STANDSUMMER</span> gets free access through September 1</div>

    <!-- HEADER -->
    <header class="lp-head">
      <a href="https://standkids.com" aria-label="Stand"><img src="/brand/logo.svg" alt="Stand" height="30" /></a>
      <div class="lp-head-right">
        <a href={APP} class="lp-login">Already have an account? <strong>LOG IN</strong></a>
        <a href={APP} class="lp-btn lp-head-cta">Start Building <span aria-hidden="true">&rarr;</span></a>
      </div>
    </header>

    <!-- HERO -->
    <section class="lp-hero">
      <div class="lp-wrap">
        <div>
          <p class="lp-eyebrow">A real apparel business — ages 6 to 16</p>
          <h1>Your kid designs the hoodie. We ship the real thing. <img class="lp-forreal-img" src="/brand/STAND_ForReal.svg" alt="For Real." /></h1>
          <p class="sub">From a blank hoodie to a real online store the whole team can order from — Stand walks your kid through designing real apparel, branding it, pricing it, and opening a real, shareable store. The garments ship printed and embroidered, and nothing goes live until a parent says yes.</p>
          <div class="cta-row">
            <a href={APP} class="lp-btn">Start your kid's apparel business <span aria-hidden="true">&rarr;</span></a>
            <a href="#journey" class="lp-btn lp-btn--ghost">See how it works</a>
          </div>
          <p class="lp-cta-note">Free all summer with code STANDSUMMER — pay nothing until September 1.</p>
        </div>
        <div class="lp-hero-stage" aria-hidden="true">
          <div class="hero-blob"></div>
          <img class="hero-hoodie" src="/brand/STAND_PNG_PinkHoodie.webp" alt="" />
          <div class="hero-kicker">Designed entirely by a kid. Really.</div>
        </div>
      </div>
    </section>

    <!-- MARQUEE -->
    <div class="lp-marquee" aria-hidden="true">
      <div class="lp-marquee-inner">
        <span>Dream. Build. Grow. <em>&rarr;</em> Create your brand. <em>&rarr;</em> Design the hoodie. <em>&rarr;</em> Set an honest price. <em>&rarr;</em> Open a real store. <em>&rarr;</em> Outfit the whole team. <em>&rarr;</em></span>
        <span>Dream. Build. Grow. <em>&rarr;</em> Create your brand. <em>&rarr;</em> Design the hoodie. <em>&rarr;</em> Set an honest price. <em>&rarr;</em> Open a real store. <em>&rarr;</em> Outfit the whole team. <em>&rarr;</em></span>
      </div>
    </div>

    <!-- HOW IT WORKS -->
    <section class="lp-how lp-section">
      <div class="lp-wrap">
        <div class="lp-sec-head">
          <p class="lp-eyebrow">Kid-built, parent-cleared</p>
          <h2>They build it. You say yes. It ships.</h2>
        </div>
        <div class="lp-grid-3">
          <div class="lp-how-card"><div class="lp-how-num">1</div><h3>Your kid builds</h3><p>They name the brand, design the logo, create the hoodie or cap, set the price, and write the pitch — guided step by step by a patient AI coach.</p></div>
          <div class="lp-how-card is-approve"><div class="lp-how-num">2</div><h3>A parent says yes</h3><p>Before the shop can go live, a parent has to give consent — a built-in gate. No ads, no data selling, and the AI coach is always disclosed as an AI.</p></div>
          <div class="lp-how-card"><div class="lp-how-num">3</div><h3>The real thing ships</h3><p>When a teammate's family orders, the garment is actually printed or embroidered and mailed to their door — one order at a time, made to size.</p></div>
        </div>
      </div>
    </section>

    <!-- TEAM / ROSTER WEDGE -->
    <section class="lp-section lp-team">
      <div class="lp-wrap">
        <div class="lp-team-panel">
          <p class="lp-eyebrow">The apparel wedge</p>
          <h2>One kid outfits the whole team — zero inventory risk to any family.</h2>
          <p class="lp-team-lead">A kid on the roster designs the team cap and hoodie, the store link goes in the group chat, and every family orders their own size. Because it's print-on-demand, each garment is made only when it's ordered — so nobody fronts a bulk order and nobody's garage fills with leftovers.</p>
          <div class="lp-team-proofs">
            <span>No size spreadsheet.</span>
            <span>No bulk order to front.</span>
            <span>No leftover boxes.</span>
          </div>
        </div>
      </div>
    </section>

    <!-- INSIDE STAND — real app screenshots -->
    <section class="lp-section lp-inside">
      <div class="lp-wrap">
        <div class="lp-sec-head">
          <p class="lp-eyebrow">Inside Stand</p>
          <h2>This is the actual software your kid uses.</h2>
          <p>Not a slideshow. A real, guided workspace — with an AI coach narrating every step, the whole business on one screen, and honest money math built in.</p>
        </div>
        <div class="lp-grid-3">
          <div>
            <div class="lp-shot"><img src="/app-screens/hat-workshop.png" alt="Stand's Product Lab — designing a real garment with the AI coach" loading="lazy" /></div>
            <p class="lp-shot-cap">A real product lab, guided by AI</p>
          </div>
          <div>
            <div class="lp-shot"><img src="/app-screens/hoodie-receipt.png" alt="Stand's Money Math lesson — the live hoodie receipt: price, cost, shipping, card fee, and what the kid keeps" loading="lazy" /></div>
            <p class="lp-shot-cap">Real money math, built in</p>
          </div>
          <div>
            <div class="lp-shot"><img src="/app-screens/hat-storefront.png" alt="The Stand storefront — a kid's apparel business on one screen" loading="lazy" /></div>
            <p class="lp-shot-cap">The whole business on one screen</p>
          </div>
        </div>
      </div>
    </section>

    <!-- LEARNING JOURNEY -->
    <section id="journey" class="lp-section" style="background:var(--stand-white);border-top:2px solid var(--lp-ink);border-bottom:2px solid var(--lp-ink);">
      <div class="lp-wrap">
        <div class="lp-sec-head">
          <p class="lp-eyebrow">The Stand Toolbox</p>
          <h2>Six real skills, learned by doing each one.</h2>
          <p>Every tool in Stand teaches a skill by making your kid actually use it. No worksheets. No lectures. Just doing.</p>
        </div>
        <div class="lp-carousel" data-lp-carousel>
          <button class="lp-carousel-nav prev" type="button" aria-label="Previous tool">&#8249;</button>
          <button class="lp-carousel-nav next" type="button" aria-label="Next tool">&#8250;</button>
          <div class="lp-carousel-track">
            {journey.map((j) => (
              <article class="lp-jcard">
                <img class="tool" src={`/brand/icon-${j.tool}.png`} alt="" loading="lazy" />
                <div class="step">{j.step}</div>
                <h3>{j.name}</h3>
                <p class="row"><b>They do</b>{j.do}</p>
                <p class="row"><b>They learn</b>{j.learn}</p>
                <div class="proof">{j.proof}</div>
              </article>
            ))}
          </div>
        </div>
        <p class="lp-journey-close">From sketch to <span class="lp-forreal">sold.</span></p>
      </div>
    </section>

    <!-- WHAT THEY MAKE -->
    <section class="lp-products lp-section">
      <div class="lp-wrap">
        <div class="lp-sec-head">
          <p class="lp-eyebrow">Find your business — clothes &amp; apparel</p>
          <h2>Real gear. What they design is what ships.</h2>
          <p>No pretend previews. The design your kid finishes in the Product Lab is the file a real fulfillment partner runs when someone orders — printed or stitched, one order at a time.</p>
        </div>
        <div class="lp-grid-2">
          <div class="lp-prod">
            <div class="lp-prod-visual contain" style="background:var(--stand-pink);"><img src="/brand/STAND_PNG_PinkHoodie.webp" alt="A Stand youth hoodie" /></div>
            <h3>Youth Hoodie</h3>
            <ul>
              <li>Their own design, printed direct-to-garment or embroidered</li>
              <li>Real apparel kids wear to school and on weekends</li>
              <li>Print-on-demand — made only when a teammate or cousin orders</li>
            </ul>
            <div class="lp-ships">Printed per order &middot; Really ships</div>
          </div>
          <div class="lp-prod">
            <div class="lp-photo-ph"><span>Real photo — a designed crewneck on a kid (PRD &sect;10)</span></div>
            <h3>Youth Crewneck Sweatshirt</h3>
            <ul>
              <li>Clean and soft — the everyday layer people actually reach for</li>
              <li>Pick the colorway that fits the team, the club, or the crew</li>
              <li>Drop your design on the front and that's the real sweatshirt that ships</li>
            </ul>
            <div class="lp-ships">Printed per order &middot; Really ships</div>
          </div>
        </div>
      </div>
    </section>

    <!-- USE CASES -->
    <section class="lp-section">
      <div class="lp-wrap">
        <div class="lp-sec-head">
          <p class="lp-eyebrow">Picture your kid</p>
          <h2>Six groups that already want matching gear.</h2>
          <p>Apparel's superpower: every team, club, and crew is a built-in customer list of families who all want the same thing.</p>
        </div>
        <div class="lp-grid-3">
          {useCases.map((u) => (
            <div class={`lp-uc${u.wide ? " is-wide" : ""}`}><h3>{u.h}</h3><p>{u.p}</p><div class="who">{u.who}</div></div>
          ))}
        </div>
      </div>
    </section>

    <!-- MONEY -->
    <section class="lp-money lp-section" style="background:var(--stand-white);border-top:2px solid var(--lp-ink);border-bottom:2px solid var(--lp-ink);">
      <div class="lp-wrap">
        <div>
          <p class="lp-eyebrow">Money — the lesson parents love</p>
          <h2 style="font-size:40px;margin-top:14px;">Real numbers. A real lesson. No pretend profit.</h2>
          <p style="margin-top:16px;color:var(--lp-ink-70);font-size:18px;">When your kid sets a price, Stand shows the live math — real production and shipping costs and the real card-processing fee. Stand takes no cut of your kid's sales. If they price too low, the screen shows a loss — and they learn why.</p>
          <p class="lp-lesson">It teaches money. It never promises money. The lesson ends the way real money decisions do: reinvest, save, spend, or donate.</p>
        </div>
        <div class="lp-receipts">
          <div class="lp-receipt" aria-label="Example margin receipt — crewneck sweatshirt">
            <div class="r-title">One crewneck, sold — the live math</div>
            <div class="row"><span>Sweatshirt</span><span>$45.00</span></div>
            <div class="row"><span>Making the real thing</span><span>&minus;$14.07</span></div>
            <div class="row"><span>Shipping</span><span>&minus;$5.99</span></div>
            <div class="row"><span>Card fee (2.9% + 30¢)</span><span>&minus;$1.61</span></div>
            <div class="row total"><span>Your kid keeps</span><span>$23.33</span></div>
            <p class="note">Real numbers — the app's default price and true costs (52% margin). Stand takes no cut.</p>
          </div>
          <div class="lp-receipt" aria-label="Example margin receipt — youth hoodie">
            <div class="r-title">One hoodie, sold — the live math</div>
            <div class="row"><span>Hoodie</span><span>$49.00</span></div>
            <div class="row"><span>Making the real thing</span><span>&minus;$16.56</span></div>
            <div class="row"><span>Shipping</span><span>&minus;$5.99</span></div>
            <div class="row"><span>Card fee (2.9% + 30¢)</span><span>&minus;$1.72</span></div>
            <div class="row total"><span>Your kid keeps</span><span>$24.73</span></div>
            <p class="note">Real numbers — the app's default price and true costs (50% margin). Stand takes no cut.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FOUNDER LETTER -->
    <section class="lp-section">
      <div class="lp-wrap">
        <div class="lp-letter-wrap lp-letter">
          <div class="lp-letter-photo lp-photo-ph"><span>Real photo — the founder (PRD &sect;10)</span></div>
          <div>
            <p class="lp-eyebrow">Why we built Stand</p>
            <h2>A real business — because pretend wasn't enough.</h2>
            <p class="lp-sample-tag" style="margin-bottom:14px;">Placeholder — replace with a real, signed founder letter</p>
            <p>[Founder letter — 4 to 6 sentences, first person. The origin: why a real shop that really ships beats a worksheet or an app that's secretly a game. The thing every kid should walk away with: the proof they can make a real thing and put it into the world.]</p>
            <p>[Close on the parent: you don't have to be an entrepreneur to raise one. Stand does the heavy lifting — the tools, the coach, the printing, the shipping. You just say yes.]</p>
            <p class="sig">— [Founder name]</p>
            <p class="sig-name">[Title], Stand Kids Inc</p>
          </div>
        </div>
      </div>
    </section>

    <!-- SOCIAL PROOF -->
    <section class="lp-proof lp-section">
      <div class="lp-wrap">
        <div class="lp-sec-head">
          <p class="lp-eyebrow">Real families</p>
          <h2>What parents say.</h2>
        </div>
        <div class="lp-grid-3">
          <div class="lp-tcard pink"><p>"Watching her take orders, handle her own money, and stay proud of something she built herself. That's the stuff you can't teach in a classroom."</p><div class="name">— Parent of Lily, age 12</div></div>
          <div class="lp-tcard mustard"><p>"I thought starting a business would be easy. Then I had to make decisions, set prices, and keep going when it got hard. STAND helped me figure it out."</p><div class="name">— Ryan, age 10</div></div>
          <div class="lp-tcard postit"><p>"He cared about every detail — the name, the logo, the product, the packaging. STAND turned his creativity into something structured."</p><div class="name">— Parent of Leo, 13</div></div>
        </div>
      </div>
    </section>

    <!-- TRUST -->
    <section class="lp-section">
      <div class="lp-wrap">
        <div class="lp-sec-head">
          <p class="lp-eyebrow">Safety &amp; trust</p>
          <h2>You don't have to be an entrepreneur to raise one.</h2>
          <p>Kids lead. You stay in control of what matters — and you never have to teach a thing you don't already know.</p>
        </div>
        <div class="lp-trust-grid is-single">
          <div>
            <div class="lp-check" set:html={Check + "<span>Nothing goes live until a parent gives consent — a built-in gate before the shop opens.</span>"}></div>
            <div class="lp-check" set:html={Check + "<span>COPPA compliant — no personal data shared or sold, and no ads, ever.</span>"}></div>
            <div class="lp-check" set:html={Check + "<span>Every image — generated or uploaded — is AI-moderated before it's used. If the check can't run, it's blocked.</span>"}></div>
            <div class="lp-check" set:html={Check + "<span>The AI coach is always disclosed as an AI — age-appropriate and moderated.</span>"}></div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="lp-faq lp-section">
      <div class="lp-wrap">
        <div class="lp-sec-head">
          <p class="lp-eyebrow">Questions parents actually ask</p>
          <h2>The honest answers.</h2>
        </div>
        {faqs.map((f) => (
          <details><summary>{f.q}</summary><p>{f.a}</p></details>
        ))}
      </div>
    </section>

    <!-- BECOMING A BUILDER -->
    <section class="lp-section" style="background:var(--stand-white);border-top:2px solid var(--lp-ink);">
      <div class="lp-wrap">
        <div class="lp-manifesto">
          <p class="lp-eyebrow">The long game</p>
          <h2>It's not an apparel business. It's a <span class="lp-forreal">builder.</span></h2>
          <p>The goal was never a perfect shop at age nine. It's a kid who learns, for real, that they can make something and put it into the world — and the quiet confidence to do it again. Built for them. And for you.</p>
        </div>
      </div>
    </section>

    <!-- PRICING + CLOSE -->
    <section class="lp-close lp-section" id="pricing">
      <div class="lp-wrap">
        <div class="lp-price">
          <div class="flag">Summer on us — code STANDSUMMER</div>
          <p class="lp-eyebrow" style="color:var(--lp-ink-55);">This summer, the whole thing is free</p>
          <div class="amount"><span class="strike">$99/yr</span>$0<small> until Sept 1</small></div>
          <p class="reframe">$99/yr after the summer — less than $2 a week.</p>
          <p style="color:var(--lp-ink-70);margin-top:6px;">Use code STANDSUMMER for full access all summer — the journey, the coach, the real store, real orders. The whole season's gear, sorted. Pay only if you continue after September 1.</p>
          <ul>
            <li set:html={Check + "<span>The full six-step journey with the AI coach</span>"}></li>
            <li set:html={Check + "<span>A real, shareable shop — opened only after a parent consents</span>"}></li>
            <li set:html={Check + "<span>Printing, embroidery, and shipping, handled per order</span>"}></li>
            <li set:html={Check + "<span>The full parent dashboard</span>"}></li>
          </ul>
          <a href={APP} class="lp-btn" style="width:100%;justify-content:center;">Start your kid's apparel business <span aria-hidden="true">&rarr;</span></a>
        </div>
        <h2>Stand by your kid — and turn their team's idea into something <span class="lp-forreal">real.</span></h2>
        <p class="sub">This summer, trying it costs nothing. After September 1, it's $99/yr — less than $2 a week.</p>
        <a href={APP} class="lp-btn">Start your kid's apparel business <span aria-hidden="true">&rarr;</span></a>
        <p class="lp-cta-note">Free all summer with code STANDSUMMER. A parent consents before anything goes live.</p>
      </div>
    </section>

    <Footer />
  </div>
</Layout>

<script>
  // Click-through carousel for the learning-journey cards.
  document.querySelectorAll<HTMLElement>("[data-lp-carousel]").forEach((root) => {
    const track = root.querySelector<HTMLElement>(".lp-carousel-track");
    if (!track) return;
    const stepBy = () => {
      const card = track.querySelector<HTMLElement>(".lp-jcard");
      return card ? card.getBoundingClientRect().width + 22 : 360;
    };
    root.querySelector(".lp-carousel-nav.prev")?.addEventListener("click", () =>
      track.scrollBy({ left: -stepBy(), behavior: "smooth" })
    );
    root.querySelector(".lp-carousel-nav.next")?.addEventListener("click", () =>
      track.scrollBy({ left: stepBy(), behavior: "smooth" })
    );
  });
</script>


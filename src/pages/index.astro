---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/Hero.astro';
import About from '@/components/About.astro';
import FindYourBusiness from '@/components/FindYourBusiness.astro';
import Marquee from '@/components/Marquee.astro';
import IconTicker from '@/components/IconTicker.astro';
import Toolbox from '@/components/Toolbox.astro';
import ExtraBio from '@/components/ExtraBio.astro';
import SafetyTrust from '@/components/SafetyTrust.astro';
import Why from '@/components/Why.astro';
import StartNow from '@/components/StartNow.astro';
import Footer from '@/components/Footer.astro';
---

<Layout>
  <main>
    <Hero />
    <About />
    <FindYourBusiness />
    <Marquee items={[{ text: 'Dream. Build. Grow.', font: 'sans' }, { text: 'What will you build?', font: 'serif' }]} height={56} />
    <Toolbox />
    <IconTicker />
    <ExtraBio />
    <SafetyTrust />
    <Why />
    <StartNow />
  </main>
  <Footer />
</Layout>

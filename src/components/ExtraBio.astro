---
// EXTRA BIO + TESTIMONIALS — Figma node 113:244
// Two text blocks + a stacked testimonial deck. Each card uses Faye's exported
// rectangle PNG as the colored background with text overlaid. Arrow click rotates
// the deck so the next card moves to the front.

interface Testimonial {
  bg: string;          // basename in /brand/ for the colored rectangle PNG
  quote: string;
  byline: string;
}

const testimonials: Testimonial[] = [
  {
    bg: 'testimonial-pink',
    quote: 'Watching her take orders, handle her own money, and stay proud of something she built herself. That’s the stuff you can’t teach in a classroom.',
    byline: '— Parent of Lily, age 12',
  },
  {
    bg: 'testimonial-mustard',
    quote: 'I thought starting a business would be easy. Then I had to make decisions, set prices, and keep going when it got hard. STAND helped me figure it out.',
    byline: '— Ryan, age 10',
  },
  {
    bg: 'testimonial-yellow',
    quote: 'He cared about every detail - the name, the logo, the product, the packaging. STAND turned his creativity into something structured.',
    byline: '— Parent of Leo, 13',
  },
];
---

<section class="extra-bio">
  <div class="inner">
    <p class="eyebrow">Kid &amp; Parent Approved</p>
    <h2 class="headline">STAND is designed for kids to lead and parents to support.</h2>

    <div class="copy">
      <p>
        Kids gain the independence and pride of building something of their own. Parents get the
        structure, oversight, and safety needed to make the experience age-appropriate. STAND is
        not just another app. It&rsquo;s a hands-on way for kids to build confidence, creativity,
        communication skills, financial literacy, and real-world initiative.
      </p>
    </div>

    <div class="deck" id="testimonial-deck">
      <button class="nav prev" aria-label="Previous testimonial">
        <svg viewBox="0 0 64 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="52" y1="8" x2="12" y2="8" />
          <polyline points="20,3 12,8 20,13" />
        </svg>
      </button>

      <div class="stack">
        {
          testimonials.map((t, i) => (
            <article class="card" data-index={i} data-pos={i}>
              <picture class="bg" aria-hidden="true">
                <source srcset={`/brand/${t.bg}.webp`} type="image/webp" />
                <img src={`/brand/${t.bg}.png`} alt="" loading="eager" />
              </picture>
              <div class="content">
                <blockquote>&ldquo;{t.quote}&rdquo;</blockquote>
                <p class="byline">{t.byline}</p>
              </div>
            </article>
          ))
        }
      </div>

      <button class="nav next" aria-label="Next testimonial">
        <svg viewBox="0 0 64 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="12" y1="8" x2="52" y2="8" />
          <polyline points="44,3 52,8 44,13" />
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
  const deck = document.getElementById('testimonial-deck');
  if (deck) {
    const cards = Array.from(deck.querySelectorAll<HTMLElement>('.card'));
    const prev = deck.querySelector('.nav.prev') as HTMLButtonElement;
    const next = deck.querySelector('.nav.next') as HTMLButtonElement;
    const n = cards.length;
    let front = 0;

    const sync = () => {
      cards.forEach((card, i) => {
        card.dataset.pos = String((i - front + n) % n);
      });
    };

    prev?.addEventListener('click', () => { front = (front - 1 + n) % n; sync(); });
    next?.addEventListener('click', () => { front = (front + 1) % n; sync(); });
  }
</script>

<style>
  .extra-bio {
    background: var(--stand-cream);
    padding: clamp(48px, 7vh, 100px) 0;
    width: 100%;
  }

  .inner {
    max-width: calc(var(--container-max) * 0.75);
    margin: 0 auto;
    padding: 0 70px;
  }

  .eyebrow {
    font-family: var(--font-serif);
    font-weight: 300;
    line-height: 1.18;
    letter-spacing: -0.33px;
    color: var(--stand-black);
    margin: 0 0 24px;
  }

  .headline {
    font-family: var(--font-sans);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.75px;
    color: var(--stand-black);
    margin: 0 0 20px;
    max-width: 938px;
  }

  .copy {
    max-width: 938px;
    margin-bottom: 90px;
  }

  .copy p {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 14px;
    line-height: 1.3;
    letter-spacing: -0.24px;
    color: var(--stand-black);
    margin: 0 0 18px;
  }

  .deck {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 40px;
  }

  .nav {
    flex-shrink: 0;
    width: 72px;
    height: 36px;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--stand-black);
    cursor: pointer;
    z-index: 5;
  }

  .nav svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .stack {
    position: relative;
    flex: 1 1 auto;
    min-width: 0;
    max-width: 540px;
    aspect-ratio: 993 / 762;
    container-type: inline-size;
  }

  .card {
    position: absolute;
    inset: 0;
    transition: transform 400ms cubic-bezier(0.2, 0.7, 0.2, 1), opacity 400ms ease;
    transform-origin: center;
  }

  .card[data-pos='0'] { transform: rotate(-3deg); z-index: 3; }
  .card[data-pos='1'] { transform: rotate(6deg) translate(4%, 3%); z-index: 2; }
  .card[data-pos='2'] { transform: rotate(-9deg) translate(-4%, 4%); z-index: 1; }

  .bg,
  .bg img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
  }

  .content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 8% 14%;
    z-index: 1;
  }

  /* Only the front card shows its text; back cards just show their color. */
  .card:not([data-pos='0']) .content {
    opacity: 0;
  }

  /* Counter-rotate the front card's text by +3deg so the quote stays upright
     while the card frame keeps its tilt from `.card[data-pos='0']`. */
  .card[data-pos='0'] .content {
    transform: rotate(3deg);
  }

  blockquote {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 26px;
    line-height: 1.15;
    letter-spacing: -0.45px;
    color: var(--stand-black);
    margin: 0 0 24px;
    max-width: 450px;
  }

  .byline {
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.2;
    letter-spacing: -0.27px;
    color: var(--stand-black);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .extra-bio { padding: 90px 0 60px; }
    .copy p { font-size: 14px; }
    .deck { gap: 24px; }
    .copy { margin-bottom: 75px; }
  }

  @media (max-width: 768px) {
    .extra-bio {
      padding: 60px 0;
    }
    .inner {
      padding: 0 10%;
      max-width: var(--container-max);
    }
    .eyebrow {
      font-size: 10px;
      line-height: 1.1;
      letter-spacing: 0;
      margin-bottom: 8px;
    }
    .headline {
      font-size: 22px;
      line-height: 0.98;
      letter-spacing: 0;
      margin-bottom: 24px;
    }
    .copy {
      margin-bottom: 60px;
    }
    .copy p {
      font-size: 16px;
      margin-bottom: 16px;
    }
    .deck { gap: 0; }
    .nav { display: none; }
    .stack { max-width: none; }
    .content { padding: 28px 24px; }
    blockquote {
      font-size: 18px;
      line-height: 1.25;
      margin-bottom: 16px;
      max-width: none;
    }
    .byline {
      font-size: 12px;
    }
  }
</style>

---
// EXTRA BIO + TESTIMONIALS — Figma node 113:244
// Two text blocks + a 3-card testimonial carousel. Each card uses Faye's exported
// rectangle PNG (Frame 29 / 30 / 31) as the colored background with text overlaid.
// Arrow click swipes to the next testimonial.

interface Testimonial {
  bg: string;          // basename in /brand/ for the colored rectangle PNG
  quote: string;
  byline: string;
}

const testimonials: Testimonial[] = [
  {
    bg: 'testimonial-pink',
    quote: 'Watching her take orders, handle her own money, and stay proud of something she built herself. That’s the stuff you can’t teach in a classroom.',
    byline: '— Parent of Lily, age 9',
  },
  {
    bg: 'testimonial-mustard',
    quote: 'I didn’t know what to charge at first but Stand helped me figure it out. Now I actually understand profit.',
    byline: '— Maya, age 11',
  },
  {
    bg: 'testimonial-yellow',
    quote: 'She had a slow month and instead of quitting she changed her prices and tried a new product. I didn’t tell her to do that. Stand did.',
    byline: '— Parent of Olivia, age 10',
  },
];
---

<section class="extra-bio">
  <div class="inner">
    <p class="eyebrow">Kid &amp; Parent Approved</p>
    <h2 class="headline">STAND is designed for kids to lead and parents to support.</h2>

    <div class="copy">
      <p>
        Kids gain the independence and pride of building something of their own. Parents get the
        structure, oversight, and safety needed to make the experience age-appropriate.
      </p>
      <p>
        STAND&reg; is not just another app. It&rsquo;s a hands-on way for kids to build confidence,
        creativity, communication skills, financial literacy, and real-world initiative.
      </p>
    </div>

    <div class="carousel" id="testimonial-carousel">
      <button class="nav prev" aria-label="Previous testimonial">←</button>

      <div class="track-clip">
        <div class="track">
          {
            testimonials.map((t, i) => (
              <article class="testimonial" data-index={i}>
                <picture class="bg" aria-hidden="true">
                  <source srcset={`/brand/${t.bg}.webp`} type="image/webp" />
                  <img src={`/brand/${t.bg}.png`} alt="" loading={i === 0 ? 'eager' : 'lazy'} />
                </picture>
                <div class="content">
                  <blockquote>&ldquo;{t.quote}&rdquo;</blockquote>
                  <p class="byline">{t.byline}</p>
                </div>
              </article>
            ))
          }
        </div>
      </div>

      <button class="nav next" aria-label="Next testimonial">→</button>
    </div>
  </div>
</section>

<script>
  const carousel = document.getElementById('testimonial-carousel');
  if (carousel) {
    const track = carousel.querySelector('.track') as HTMLElement;
    const prev = carousel.querySelector('.nav.prev') as HTMLButtonElement;
    const next = carousel.querySelector('.nav.next') as HTMLButtonElement;
    let index = 0;

    const update = () => {
      const card = track.querySelector('.testimonial') as HTMLElement;
      if (!card) return;
      const offset = card.offsetWidth + 32;
      track.style.transform = `translateX(${-index * offset}px)`;
    };

    prev?.addEventListener('click', () => {
      index = Math.max(0, index - 1);
      update();
    });
    next?.addEventListener('click', () => {
      const max = track.querySelectorAll('.testimonial').length - 1;
      index = Math.min(max, index + 1);
      update();
    });

    window.addEventListener('resize', update);
    requestAnimationFrame(update);
  }
</script>

<style>
  .extra-bio {
    background: var(--stand-cream);
    padding: 174px 0 100px;
    width: 100%;
  }

  .inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 94px;
  }

  .eyebrow {
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: clamp(16px, 2.088vw, 30px);
    line-height: 1.18;
    letter-spacing: -0.6px;
    color: var(--stand-black);
    margin: 0 0 32px;
  }

  .headline {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(36px, 4.524vw, 65px);
    line-height: 1;
    letter-spacing: -1.5px;
    color: var(--stand-black);
    margin: 0 0 60px;
    max-width: 1250px;
  }

  .copy {
    max-width: 1250px;
    margin-bottom: 140px;
  }

  .copy p {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(16px, 1.531vw, 22px);
    line-height: 1.2;
    letter-spacing: -0.44px;
    color: var(--stand-black);
    margin: 0 0 24px;
  }

  .carousel {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 80px;
  }

  .nav {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    background: transparent;
    color: var(--stand-black);
    font-size: 32px;
    line-height: 1;
    z-index: 5;
  }

  .track-clip {
    width: 993px;
    max-width: 100%;
    overflow: hidden;
    padding: 20px 4px 30px;
  }

  .track {
    display: flex;
    gap: 32px;
    transition: transform 450ms cubic-bezier(0.2, 0.7, 0.2, 1);
  }

  .testimonial {
    position: relative;
    flex: 0 0 993px;
    aspect-ratio: 993 / 762;
  }

  .bg,
  .bg img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
  }

  .content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    /* The PNG card is rotated/skewed, so its visible area is inset from the
       bounding box. Extra horizontal padding keeps text inside the colored card. */
    padding: 80px 160px;
    z-index: 1;
  }

  blockquote {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(20px, 2.644vw, 38px);
    line-height: 1.15;
    letter-spacing: -0.76px;
    color: var(--stand-black);
    margin: 0 0 32px;
    max-width: 600px;
  }

  .byline {
    font-family: var(--font-serif);
    font-size: clamp(16px, 1.740vw, 25px);
    line-height: 1.2;
    letter-spacing: -0.5px;
    color: var(--stand-black);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .extra-bio { padding: 120px 0 80px; }
    .headline { font-size: 52px; }
    .copy p { font-size: 22px; }
    .carousel { gap: 32px; }
    .track-clip { width: 100%; max-width: 720px; }
    .testimonial { flex-basis: 100%; }
    .content { padding: 50px 100px; }
    blockquote { font-size: 26px; max-width: 460px; }
    .copy { margin-bottom: 100px; }
  }

  @media (max-width: 768px) {
    .extra-bio {
      padding: 60px 0;
    }
    .inner {
      padding: 0 20px;
    }
    .eyebrow {
      font-size: 22px;
      margin-bottom: 20px;
    }
    .headline {
      font-size: 28px;
      line-height: 1.05;
      letter-spacing: -0.3px;
      margin-bottom: 24px;
    }
    .copy {
      margin-bottom: 60px;
    }
    .copy p {
      font-size: 16px;
      margin-bottom: 16px;
    }
    .carousel { gap: 12px; }
    .track-clip { width: calc(100% - 96px); }
    .content { padding: 28px 24px; }
    blockquote {
      font-size: 18px;
      line-height: 1.2;
      margin-bottom: 16px;
    }
    .byline {
      font-size: 13px;
    }
    .nav { width: 36px; height: 36px; font-size: 22px; }
  }
</style>

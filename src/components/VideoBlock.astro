---
// VIDEO BLOCK — the film, between the header and the hero.
// AUTOPLAYS on load, MUTED + looping. Browsers BLOCK autoplay with sound, so
// muted is required; a corner "sound" button unmutes (that click is the gesture
// browsers need). Respects prefers-reduced-motion (no autoplay — poster shown,
// sound button still starts it). Hosted on Vercel Blob (`stand-media` store),
// pristine 1080p (CRF 18), V2 cut.
const VIDEO_URL =
  'https://mk7xj0szdtkawdqj.public.blob.vercel-storage.com/video/stand-website-v2-RzQBNxWaJiAOJwSAv6dveovpSRwsLH.mp4';
---

<section class="film" aria-label="Stand film">
  <div class="inner">
    <figure class="player" id="film-player">
      <video
        class="video"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        poster="/video/poster.jpg"
        aria-label="Stand — the film"
      >
        <source src={VIDEO_URL} type="video/mp4" />
        Your browser can&rsquo;t play this video.
      </video>

      <button class="sound" id="film-sound" type="button" aria-pressed="false" aria-label="Turn sound on">
        <svg class="ico off" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
          <path fill="currentColor" d="M4 9v6h4l5 4V5L8 9H4z" />
          <path stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M16.5 9.5l4 5M20.5 9.5l-4 5" />
        </svg>
        <svg class="ico on" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
          <path fill="currentColor" d="M4 9v6h4l5 4V5L8 9H4z" />
          <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M16.5 8.5a4.5 4.5 0 010 7M19 6a8 8 0 010 12" />
        </svg>
        <span class="label">sound on</span>
      </button>
    </figure>
  </div>
</section>

<script>
  const wrap = document.getElementById('film-player');
  if (wrap) {
    const video = wrap.querySelector('video');
    const btn = document.getElementById('film-sound');
    const label = btn && btn.querySelector('.label');
    if (video && btn && label) {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce) {
        // Don't autoplay for reduced-motion users — hold on the poster.
        video.autoplay = false;
        video.loop = false;
        video.pause();
        video.currentTime = 0;
      } else {
        // Belt-and-suspenders: kick playback if the attribute didn't fire
        // (still muted, so no gesture needed).
        video.play().catch(() => {});
      }

      const sync = () => {
        const on = !video.muted && !video.paused;
        wrap.classList.toggle('sound-on', on);
        btn.setAttribute('aria-pressed', String(on));
        btn.setAttribute('aria-label', on ? 'Turn sound off' : 'Turn sound on');
        label.textContent = on ? 'sound off' : 'sound on';
      };

      btn.addEventListener('click', () => {
        if (video.muted) {
          video.muted = false;
          if (video.paused) video.play().catch(() => {}); // start it if reduced-motion / stalled
        } else {
          video.muted = true;
        }
        sync();
      });

      video.addEventListener('volumechange', sync);
      video.addEventListener('play', sync);
      video.addEventListener('pause', sync);
      sync();
    }
  }
</script>

<style>
  .film {
    background: var(--stand-cream);
    padding: clamp(16px, 4vh, 56px) 0 clamp(28px, 6vh, 72px);
  }
  .inner {
    max-width: min(1080px, 92%);
    margin: 0 auto;
  }
  .player {
    position: relative;
    margin: 0;
    aspect-ratio: 16 / 9;
    border-radius: 18px;
    overflow: hidden;
    border: 2px solid var(--stand-black);
    box-shadow: 8px 8px 0 rgba(0, 0, 0, 0.12);
    background: var(--stand-black);
  }
  .video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Sound toggle — the film is muted on autoplay; this turns audio on. */
  .sound {
    position: absolute;
    right: clamp(12px, 2vw, 18px);
    bottom: clamp(12px, 2vw, 18px);
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 15px 9px 12px;
    border: 2px solid var(--stand-black);
    border-radius: 999px;
    background: var(--stand-red);
    color: var(--stand-white);
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.32);
  }
  .sound .ico {
    display: block;
    flex: none;
  }
  .sound .ico.on {
    display: none;
  }
  .sound-on .sound .ico.off {
    display: none;
  }
  .sound-on .sound .ico.on {
    display: block;
  }
  .sound:focus-visible {
    outline: 3px solid var(--stand-mustard);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .sound {
      transition: transform 0.15s ease;
    }
    .sound:hover {
      transform: scale(1.04);
    }
  }

  @media (max-width: 640px) {
    .player {
      border-radius: 14px;
      box-shadow: 5px 5px 0 rgba(0, 0, 0, 0.12);
    }
    .sound {
      font-size: 13px;
      padding: 8px 13px 8px 10px;
    }
  }
</style>

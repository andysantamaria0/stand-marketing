---
// TOOLBOX — Figma node 112:175
// Each slide is a full panel: illustration on top + card below. Arrow clicks
// swipe the whole panel as one unit. Illustrations use existing brand WebPs;
// swap to Faye-composed frame PNGs by replacing the `prop` field below.

// Each slide can either:
//   - Use Faye's full composed PNG (preferred — set `frame`)
//   - Or render an illustration + card dynamically from `prop` + num/name/desc
// As Faye exports more frame PNGs we just swap `frame` in below.

interface Slide {
  num: string;
  name: string;
  desc: string;
  frame?: string;       // basename in /brand/ for a full composed slide image
  prop?: string;        // basename in /brand/ for an illustration-only image
  fmt?: 'webp' | 'svg';
}

const slides: Slide[] = [
  { num: '00', name: 'dashboard',    desc: 'Tktktktktktk.', frame: 'frame-dashboard' },
  { num: '01', name: 'ideas tent',   desc: 'Tktktktktktk.', frame: 'frame-ideas-tent' },
  { num: '02', name: 'brand studio', desc: 'Create your business name, logo, colors, and brand style.', frame: 'frame-brand-studio' },
  { num: '03', name: 'product lab',  desc: 'Tktktktktktk.', frame: 'frame-product-lab' },
  { num: '04', name: 'marketing',    desc: 'Tktktktktktk.', frame: 'frame-marketing' },
];
---

<section class="toolbox">
  <div class="inner">
    <p class="eyebrow">The Stand Toolbox</p>
    <h2 class="headline">STAND provides the tools behind every kid business.</h2>

    <div class="slider" id="toolbox-slider">
      <button class="nav prev" aria-label="Previous slide">←</button>

      <div class="track-clip">
        <div class="track">
          {
            slides.map((s, i) =>
              s.frame ? (
                <article class="slide slide-frame" data-index={i}>
                  <picture>
                    <source srcset={`/brand/${s.frame}.webp`} type="image/webp" />
                    <img
                      class="frame-img"
                      src={`/brand/${s.frame}.png`}
                      alt={`${s.num} ${s.name} — ${s.desc}`}
                      loading={i < 3 ? 'eager' : 'lazy'}
                    />
                  </picture>
                </article>
              ) : (
                <article class="slide" data-index={i}>
                  <div class="feature">
                    <img
                      class="prop"
                      src={`/brand/${s.prop}.${s.fmt ?? 'webp'}`}
                      alt=""
                      aria-hidden="true"
                      loading={i < 3 ? 'eager' : 'lazy'}
                    />
                    <div class="divider"></div>
                  </div>
                  <div class="card">
                    <span class="num">{s.num}</span>
                    <h3 class="name">{s.name}</h3>
                    <p class="desc">{s.desc}</p>
                  </div>
                </article>
              )
            )
          }
        </div>
      </div>

      <button class="nav next" aria-label="Next slide">→</button>
    </div>
  </div>
</section>

<script>
  const slider = document.getElementById('toolbox-slider');
  if (slider) {
    const track = slider.querySelector('.track') as HTMLElement;
    const prev = slider.querySelector('.nav.prev') as HTMLButtonElement;
    const next = slider.querySelector('.nav.next') as HTMLButtonElement;
    let index = 2; // start on 02 / brand studio to match Figma (00 dashboard is now first)

    const update = () => {
      const slide = track.querySelector('.slide') as HTMLElement;
      if (!slide) return;
      const offset = slide.offsetWidth + 32;
      track.style.transform = `translateX(${-index * offset}px)`;
    };

    prev?.addEventListener('click', () => {
      index = Math.max(0, index - 1);
      update();
    });
    next?.addEventListener('click', () => {
      const max = track.querySelectorAll('.slide').length - 1;
      index = Math.min(max, index + 1);
      update();
    });

    window.addEventListener('resize', update);
    requestAnimationFrame(update);
  }
</script>

<style>
  .toolbox {
    background: var(--stand-cream);
    padding: 123px 0 100px;
    width: 100%;
  }

  .inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 94px;
  }

  .eyebrow {
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: 40px;
    line-height: 47px;
    letter-spacing: -0.8px;
    color: var(--stand-black);
    margin: 0 0 18px;
  }

  .headline {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 78px;
    line-height: 1;
    letter-spacing: -1.5px;
    color: var(--stand-black);
    margin: 0 0 80px;
    max-width: 1250px;
  }

  .slider {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 80px;
  }

  .nav {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    background: transparent;
    color: var(--stand-black);
    font-size: 32px;
    line-height: 1;
    z-index: 5;
  }

  .track-clip {
    width: 720px;
    max-width: 100%;
    overflow: hidden;
    padding: 8px 4px 20px;
  }

  .track {
    display: flex;
    gap: 32px;
    transition: transform 450ms cubic-bezier(0.2, 0.7, 0.2, 1);
  }

  .slide {
    flex: 0 0 720px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  /* Frame slides render Faye's composed PNG verbatim. */
  .slide-frame {
    gap: 0;
    align-items: center;
    justify-content: flex-start;
  }

  .frame-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .feature {
    position: relative;
    height: 480px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .prop {
    max-height: 100%;
    width: auto;
    max-width: 90%;
    z-index: 2;
    object-fit: contain;
  }

  .divider {
    position: absolute;
    top: 65%;
    left: -120px;
    right: -120px;
    border-top: 4px dotted var(--stand-red);
    z-index: 0;
  }

  .card {
    background: var(--stand-white);
    border: 3px solid var(--stand-black);
    box-shadow: 5px 5px 0 var(--stand-black);
    padding: 56px 58px 63px;
    text-align: center;
    height: 425px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 9px;
  }

  .num {
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: 40px;
    line-height: 47px;
    letter-spacing: -0.8px;
    color: var(--stand-black);
  }

  .name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 40px;
    line-height: 1.2;
    color: var(--stand-black);
    margin: 0;
  }

  .desc {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 30px;
    line-height: 1.2;
    letter-spacing: -0.6px;
    color: var(--stand-black);
    margin: 0;
    max-width: 592px;
  }

  @media (max-width: 1024px) {
    .slider { gap: 32px; }
    .track-clip { width: 540px; }
    .slide { flex-basis: 540px; gap: 28px; }
    .feature { height: 340px; }
    .card { padding: 36px 44px; height: auto; min-height: 360px; }
    .desc { font-size: 22px; }
  }

  @media (max-width: 768px) {
    .toolbox {
      padding: 60px 0;
    }
    .inner {
      padding: 0 20px;
    }
    .eyebrow { font-size: 22px; margin-bottom: 12px; }
    .headline {
      font-size: 28px;
      line-height: 1.05;
      letter-spacing: -0.3px;
      margin-bottom: 36px;
    }
    .slider { gap: 12px; }
    .track-clip { width: calc(100% - 96px); }
    .slide { flex: 0 0 100%; gap: 20px; }
    .feature { height: 220px; }
    .divider { left: -40px; right: -40px; }
    .card {
      padding: 28px 22px;
      height: auto;
      min-height: 220px;
      gap: 6px;
    }
    .num { font-size: 24px; line-height: 1.2; }
    .name { font-size: 28px; }
    .desc { font-size: 16px; }
    .nav { width: 36px; height: 36px; font-size: 22px; }
  }
</style>

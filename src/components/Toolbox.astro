---
// TOOLBOX — Figma node 112:175
// Coverflow-style carousel: active slide centered with full frame PNG + card,
// neighboring slides shrunk and shown as silhouette icons only. Arrows shift
// which is active; previous active animates back to silhouette.

interface Slide {
  name: string;
  desc: string;
  icon: string;       // bare 3D icon render (active state)
  silhouette: string; // colored SVG silhouette (inactive state)
  // Per-slide tweaks for the active tool icon (PNG). PNGs have varying internal
  // padding so each one may need its own scale + X/Y nudge to sit cleanly above
  // the card. Defaults: scale 1, offset 0,0.
  iconScale?: number;
  iconOffsetX?: number; // px, positive = right
  iconOffsetY?: number; // px, positive = down
}

const slides: Slide[] = [
  { name: 'ideas tent',
    desc: 'choose your business to build with Stand.',
    icon: 'icon-ideas-tent', silhouette: 'STAND_SVG_YellowLightbulb_Silhouette',
    iconScale: 0.7, iconOffsetX: 0, iconOffsetY: 0 },
  { name: 'brand studio',
    desc: 'Create your business name, logo, colors, and brand style.',
    icon: 'icon-brand-studio', silhouette: 'STAND_SVG_PinkPaint_Silhouette',
    iconScale: 1, iconOffsetX: 0, iconOffsetY: 0 },
  { name: 'product lab',
    desc: 'design your products and create what you need to make your vision a reality.',
    icon: 'icon-product-lab', silhouette: 'STAND_SVG_GreenBox_Silhouette',
    iconScale: 1, iconOffsetX: 0, iconOffsetY: 0 },
  { name: 'money',
    desc: 'price your product, set your goals and start thinking like an owner.',
    icon: 'icon-money', silhouette: 'STAND_SVG_BlueReceipt_Silhouette',
    iconScale: 1, iconOffsetX: 0, iconOffsetY: 0 },
  { name: 'marketing',
    desc: 'learn how to get the word out, launch your business and get customers.',
    icon: 'icon-marketing', silhouette: 'STAND_SVG_YellowMegaphone_Silhouette',
    iconScale: 1, iconOffsetX: 0, iconOffsetY: 0 },
  { name: 'storefront',
    desc: 'launch your shop and start taking orders.',
    icon: 'icon-storefront', silhouette: 'STAND_SVG_RedOpenSign_Silhouette',
    iconScale: 1, iconOffsetX: 0, iconOffsetY: 0 },
  { name: 'dashboard',
    desc: 'your ongoing progress, weekly to do’s, business lessons and more.',
    icon: 'icon-dashboard', silhouette: 'STAND_SVG_CreamDesk_Silhouette',
    iconScale: 1.2, iconOffsetX: 0, iconOffsetY: 0 },
];
---

<section class="toolbox">
  <div class="inner">
    <p class="eyebrow">The Stand Toolbox</p>
    <h2 class="headline">STAND provides the tools behind every kid business.</h2>

    <div class="slider" id="toolbox-slider">
      <span class="dotted-line" aria-hidden="true"></span>
      <button class="nav prev" aria-label="Previous tool">
        <svg viewBox="0 0 64 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="52" y1="8" x2="12" y2="8" />
          <polyline points="20,3 12,8 20,13" />
        </svg>
      </button>

      <div class="stage">
        {
          slides.map((s, i) => (
            <article
              class="slide"
              data-index={i}
              style={`--icon-scale:${s.iconScale ?? 1};--icon-offset-x:${s.iconOffsetX ?? 0}px;--icon-offset-y:${s.iconOffsetY ?? 0}px;`}
            >
              <div class="silhouette-wrap">
                <img
                  class="silhouette-img"
                  src={`/brand/${s.silhouette}.svg`}
                  alt={s.name}
                />
              </div>
              <div class="frame-wrap">
                <img
                  class="tool-icon"
                  src={`/brand/${s.icon}.png`}
                  alt={s.name}
                  loading={i < 3 ? 'eager' : 'lazy'}
                />
                <div class="card">
                  <h3 class="lede">{s.name}</h3>
                  <p class="desc">{s.desc}</p>
                </div>
              </div>
            </article>
          ))
        }
      </div>

      <button class="nav next" aria-label="Next tool">
        <svg viewBox="0 0 64 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="12" y1="8" x2="52" y2="8" />
          <polyline points="44,3 52,8 44,13" />
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
  const slider = document.getElementById('toolbox-slider');
  if (slider) {
    const stage = slider.querySelector('.stage') as HTMLElement;
    const prev = slider.querySelector('.nav.prev') as HTMLButtonElement;
    const next = slider.querySelector('.nav.next') as HTMLButtonElement;
    const slides = Array.from(stage.querySelectorAll('.slide')) as HTMLElement[];

    const count = slides.length;
    let active = 1; // start on 'brand studio' (now index 1 in the new order)

    const update = () => {
      slides.forEach((slide, i) => {
        // Circular distance so the coverflow neighbours wrap around the ends
        // (infinite loop): the slide before index 0 is the last slide, etc.
        let distance = i - active;
        if (distance > count / 2) distance -= count;
        if (distance < -count / 2) distance += count;
        if (distance === 0) {
          slide.dataset.pos = 'active';
        } else if (distance === -1) {
          slide.dataset.pos = 'prev';
        } else if (distance === 1) {
          slide.dataset.pos = 'next';
        } else if (distance === -2) {
          slide.dataset.pos = 'prev-2';
        } else if (distance === 2) {
          slide.dataset.pos = 'next-2';
        } else {
          slide.dataset.pos = 'hidden';
        }
      });
    };

    prev?.addEventListener('click', () => {
      active = (active - 1 + count) % count;
      update();
    });
    next?.addEventListener('click', () => {
      active = (active + 1) % count;
      update();
    });

    update();
  }
</script>

<style>
  .toolbox {
    background: var(--stand-cream);
    width: 100%;
    overflow: hidden;
    box-sizing: border-box;
    padding: clamp(48px, 7vh, 100px) 0 clamp(140px, 16vh, 220px);
    /* Slide width derived from viewport HEIGHT so the whole module (headline +
       paint can + card) fits one screen on a 13" laptop. 1.58 = frame aspect
       (724x1142); reserves room for the headline + top/bottom padding so the
       active card always has cream breathing room above the next section. */
    --slide-w: min(720px, calc((100vh - 380px) / 1.58));
  }

  .inner {
    max-width: calc(var(--container-max) * 0.75);
    margin: 0 auto;
    padding: 0 70px;
    container-type: inline-size;
  }

  .eyebrow {
    font-family: var(--font-serif);
    font-weight: 300;
    line-height: 1.18;
    letter-spacing: -0.33px;
    color: var(--stand-black);
    margin: 0 0 clamp(12px, 2.25vh, 45px);
  }

  .headline {
    font-family: var(--font-sans);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.75px;
    color: var(--stand-black);
    margin: 0 0 clamp(16px, 4vh, 48px);
    max-width: 1250px;
  }

  .slider {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 40px;
  }

  /* Arrows are pulled out of the slider's flex row and absolute-positioned
     below the silhouette line, sitting between the dotted connector and the
     active card. Vertical offset (top) is anchored to --slide-w so they keep
     their relative position as the slide scales with viewport height. */
  .nav {
    position: absolute;
    width: 96px;
    height: 48px;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--stand-black);
    z-index: 10;
    cursor: pointer;
    top: calc(var(--slide-w) * 0.65);
    transform: translate(-50%, -50%);
  }

  .nav.prev { left: calc(50% - var(--slide-w) * 1.0); }
  .nav.next { left: calc(50% + var(--slide-w) * 1.0); }

  .nav svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* Full-bleed red dotted connector threaded through the silhouette icons,
     sitting behind every slide (icons + active frame paint over it). Anchored
     to the vertical centre of the square silhouette boxes (slide height / 2). */
  .dotted-line {
    position: absolute;
    top: calc(var(--slide-w) / 2);
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100vw;
    height: 8px;
    background-image: radial-gradient(circle, var(--stand-red) 0 3.5px, transparent 4px);
    background-size: 22px 8px;
    background-repeat: repeat-x;
    background-position: center;
    z-index: 0;
    pointer-events: none;
  }

  /* Stage holds all slides absolutely-positioned, centered around the middle.
     Height fits icon (52% of frame) + margin (4cqw) + halved card (~0.34 slide-w)
     + a touch of shadow room, so we don't leave dead space below the card. */
  .stage {
    position: relative;
    flex: 1;
    height: calc(var(--slide-w) * 1.18);
    max-width: 1300px;
  }

  .slide {
    position: absolute;
    top: 0;
    left: 50%;
    width: var(--slide-w);
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    container-type: inline-size;
    transition: transform 500ms cubic-bezier(0.2, 0.7, 0.2, 1),
                opacity 300ms ease-out;
  }

  /* Frame + card visible only when active; silhouette hides on active. */
  .silhouette-wrap,
  .frame-wrap,
  .card {
    transition: opacity 300ms ease-out;
  }

  .silhouette-wrap {
    width: 100%;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .silhouette-img {
    max-width: 80%;
    max-height: 80%;
    object-fit: contain;
    /* Shift each silhouette up by half its own height so the bottom edge
       lands on the dotted line (which sits at the wrap's vertical center)
       instead of cutting through the middle of the icon. Per-slide nudges
       compose on top of that baseline shift.
       Using separate translate functions (instead of a single calc with mixed
       % + px) so the percentage and the per-slide pixel nudge can't fight each
       other in the calc parser when --icon-offset-y is a negative px value. */
    transform:
      translateX(var(--icon-offset-x, 0px))
      translateY(var(--icon-offset-y, 0px))
      translateY(-50%)
      scale(var(--icon-scale, 1));
  }

  /* Every slide is a bare icon + a live-text card. frame-wrap holds them in a
     724/1088 footprint so the coverflow scaling matches the silhouette frame. */
  .frame-wrap {
    position: absolute;
    inset: auto;
    top: 0;
    left: 0;
    width: 100%;
    aspect-ratio: 724 / 1088;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .tool-icon {
    width: 92%;
    height: 52%;
    object-fit: contain;
    /* Per-slide tuning: each PNG has its own padding, so we shift and scale
       independently. Defaults are no-op. */
    transform: translate(var(--icon-offset-x, 0px), var(--icon-offset-y, 0px)) scale(var(--icon-scale, 1));
  }

  .card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    /* Card is 35% wider than the slide so the .name (global canon = 32px on
       desktop) fits on one line. Auto-sizes vertically to its content so the
       previous fixed aspect-ratio (724 / 247) can't clip long descriptions. */
    width: 135%;
    flex: 0 0 auto;
    margin-top: 4cqw;
    background: var(--stand-white);
    border: 0.42cqw solid var(--stand-black);
    box-shadow: 0.6cqw 0.7cqw 0 var(--stand-black);
    padding: 10cqw 16cqw 14cqw;
    gap: 3cqw;
  }

  .lede {
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1;
    color: var(--stand-black);
    margin: 0;
  }

  .desc {
    font-family: var(--font-sans);
    font-weight: 300;
    line-height: 1.18;
    color: var(--stand-black);
    margin: 0;
  }

  /* Position states */
  .slide[data-pos='active'] {
    transform: translateX(-50%) scale(1);
    z-index: 5;
  }

  .slide[data-pos='active'] .silhouette-wrap {
    opacity: 0;
    pointer-events: none;
  }

  .slide[data-pos='active'] .frame-wrap {
    opacity: 1;
  }

  /* All neighbor silhouettes share one scale and sit at evenly-spaced offsets
     from center so they read as a single horizontal row of equal-sized icons
     along the dotted connector — not the previous coverflow ladder. Scale
     bumped up so the silhouettes carry visual weight along the line. */
  .slide[data-pos='prev'] {
    transform: translateX(calc(-50% - var(--slide-w) * 0.95)) scale(0.40);
    z-index: 2;
  }

  .slide[data-pos='prev'] .silhouette-wrap,
  .slide[data-pos='next'] .silhouette-wrap,
  .slide[data-pos='prev-2'] .silhouette-wrap,
  .slide[data-pos='next-2'] .silhouette-wrap {
    opacity: 1;
  }

  .slide[data-pos='prev'] .frame-wrap,
  .slide[data-pos='next'] .frame-wrap,
  .slide[data-pos='prev-2'] .frame-wrap,
  .slide[data-pos='next-2'] .frame-wrap {
    opacity: 0;
    pointer-events: none;
  }

  .slide[data-pos='next'] {
    transform: translateX(calc(-50% + var(--slide-w) * 0.95)) scale(0.40);
    z-index: 2;
  }

  .slide[data-pos='prev-2'] {
    transform: translateX(calc(-50% - var(--slide-w) * 1.55)) scale(0.40);
    z-index: 1;
  }

  .slide[data-pos='next-2'] {
    transform: translateX(calc(-50% + var(--slide-w) * 1.55)) scale(0.40);
    z-index: 1;
  }

  .slide[data-pos='hidden'] {
    transform: translateX(-50%) scale(0);
    opacity: 0;
    pointer-events: none;
    z-index: 0;
  }

  @media (max-width: 1024px) {
    /* Stage/slide/offsets all derive from --slide-w (viewport height), so they
       scale here automatically; only the arrow gap needs tightening. */
    .slider { gap: 16px; }
  }

  @media (max-width: 768px) {
    .toolbox {
      padding: 36px 0 0;
      --slide-w: 224px;
    }

    .inner {
      padding: 0;
      max-width: none;
    }

    .eyebrow,
    .headline {
      margin-left: 38px;
      margin-right: 38px;
    }

    .eyebrow {
      margin-bottom: 8px;
      font-size: 10px;
      line-height: 1.1;
    }

    .headline {
      max-width: 300px;
      font-size: 22px;
      line-height: 0.98;
      letter-spacing: 0;
      margin-bottom: 38px;
    }

    .slider {
      display: block;
      height: 350px;
      overflow: visible;
    }

    .nav {
      display: none;
    }

    .dotted-line {
      top: 94px;
      height: 4px;
      background-image: radial-gradient(circle, var(--stand-red) 0 1.6px, transparent 2px);
      background-size: 8px 4px;
    }

    .stage {
      height: 100%;
      max-width: none;
    }

    .slide {
      width: var(--slide-w);
    }

    .silhouette-wrap {
      height: 188px;
    }

    .frame-wrap {
      aspect-ratio: auto;
      height: 100%;
      overflow: visible;
    }

    .tool-icon {
      width: 100%;
      height: 190px;
      object-fit: contain;
    }

    .card {
      position: absolute;
      top: 206px;
      left: 50%;
      width: 100vw;
      min-height: 144px;
      margin: 0;
      transform: translateX(-50%);
      align-items: flex-start;
      justify-content: flex-start;
      text-align: left;
      background: var(--stand-white);
      border: 0;
      box-shadow: none;
      padding: 27px 38px 38px;
      gap: 18px;
    }

    .lede {
      font-size: 27px;
      line-height: 0.9;
      letter-spacing: 0;
    }

    .desc {
      max-width: 300px;
      font-size: 17px;
      line-height: 1.08;
      letter-spacing: 0;
    }

    .slide[data-pos='active'] {
      transform: translateX(-50%) scale(1);
    }

    .slide[data-pos='prev'] {
      transform: translateX(calc(-50% - 185px)) scale(0.36);
    }

    .slide[data-pos='next'] {
      transform: translateX(calc(-50% + 185px)) scale(0.36);
    }

    .slide[data-pos='prev-2'] {
      transform: translateX(calc(-50% - 292px)) scale(0.36);
    }

    .slide[data-pos='next-2'] {
      transform: translateX(calc(-50% + 292px)) scale(0.36);
    }
  }
</style>

---
// WHY? — Figma node 200:2146 (1437×2511)
// Cream bg with red top strip. Four numbered items zigzag down. Two real photos
// (3 girls smiling + 2 girls with phone) absolutely positioned behind items 2 and 3
// with rotated post-it / golden cards backing each photo.

const HERO_W = 1437;
const HERO_H = 2511;
const pct = (n: number, base: number) => `${(n / base) * 100}%`;

const items = [
  {
    num: '01',
    heading: 'No worksheets. No lectures. Just doing.',
    body: 'Pricing, marketing, planning. Every skill gets learned because they actually have to use it. The work is the lesson.',
    x: 215, y: 180, color: '#ffc712',
  },
  {
    num: '02',
    heading: "Confidence you can't fake or manufacture.",
    body: 'Kids learn to talk about what they built, explain why it’s good, and pitch to real people. That kind of confidence only comes from doing something real.',
    x: 787, y: 690, color: '#ff459c',
  },
  {
    num: '03',
    heading: "Money clicks differently when it's theirs.",
    body: 'Pricing, profit, saving versus spending. These things actually land when your kid earned the money themselves.',
    x: 60, y: 1439, color: '#1c499e',
  },
  {
    num: '04',
    heading: 'Reward the fails, not just the sales.',
    body: 'Stand is built for when things don’t go perfectly. Because that’s actually where kids grow the most. We don’t paper over the hard stuff.',
    x: 269, y: 2074, color: '#1f472f',
  },
];
---

<section class="why">
  <div class="strip">
    <span>Why STAND&reg;?</span>
  </div>

  <div class="canvas" style={{ aspectRatio: `${HERO_W} / ${HERO_H}` }}>
    <div
      class="photo-card photo-1"
      style={{
        '--pc-left': pct(-103, HERO_W),
        '--pc-top': pct(585, HERO_H),
        '--pc-width': pct(852, HERO_W),
      }}
    >
      <div class="card-back" style={{ background: 'var(--stand-postit)' }}></div>
      <img class="photo" src="/brand/why-photo-1.webp" alt="Three teenage girls smiling together" loading="lazy" />
    </div>

    <div
      class="photo-card photo-2"
      style={{
        '--pc-left': pct(629, HERO_W),
        '--pc-top': pct(1243, HERO_H),
        '--pc-width': pct(906, HERO_W),
      }}
    >
      <div class="card-back" style={{ background: 'var(--stand-mustard)' }}></div>
      <img class="photo" src="/brand/why-photo-2.webp" alt="Two teenage girls looking at a phone together" loading="lazy" />
    </div>

    {
      items.map((item) => (
        <button
          type="button"
          class="item"
          style={{
            '--item-left': pct(item.x, HERO_W),
            '--item-top': pct(item.y, HERO_H),
          }}
          aria-expanded="false"
        >
          <span class="badge-wrap">
            <span class="badge-shape" style={{ background: item.color }}></span>
            <img class="badge-plus" src="/brand/why-plus.svg" alt="" aria-hidden="true" />
          </span>
          <div class="text">
            <span class="num">{item.num}</span>
            <h3 class="heading">{item.heading}</h3>
            <div class="callout">
              <p>{item.body}</p>
            </div>
          </div>
        </button>
      ))
    }
  </div>
</section>

<style>
  .why {
    background: var(--stand-cream);
    width: 100%;
  }

  .strip {
    background: var(--stand-red);
    color: var(--stand-white);
    padding: 38px 50px;
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: 40px;
    line-height: 47px;
    letter-spacing: -0.8px;
  }

  .canvas {
    position: relative;
    width: 100%;
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .photo-card {
    position: absolute;
    left: var(--pc-left);
    top: var(--pc-top);
    width: var(--pc-width);
    aspect-ratio: 822 / 544;
  }

  .photo-1 {
    transform: rotate(-2.36deg);
  }

  .photo-2 {
    transform: rotate(4.54deg);
  }

  .card-back {
    position: absolute;
    inset: -4% -5% -10% 5%;
    transform: rotate(5deg);
    z-index: 0;
  }

  .photo-2 .card-back {
    transform: rotate(3deg);
  }

  .photo {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .item {
    position: absolute;
    left: var(--item-left);
    top: var(--item-top);
    display: flex;
    gap: 34px;
    align-items: flex-start;
    width: 50%;
    max-width: 660px;
    z-index: 5;
    cursor: pointer;
    /* button reset */
    background: transparent;
    border: 0;
    padding: 0;
    text-align: left;
    font: inherit;
    color: inherit;
  }

  .badge-wrap {
    flex-shrink: 0;
    position: relative;
    width: 73px;
    height: 89px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .badge-shape {
    position: absolute;
    inset: 0;
    transform: rotate(27.94deg);
    -webkit-mask-image: url('/brand/badge-mask.png');
            mask-image: url('/brand/badge-mask.png');
    -webkit-mask-size: contain;
            mask-size: contain;
    -webkit-mask-repeat: no-repeat;
            mask-repeat: no-repeat;
    -webkit-mask-position: center;
            mask-position: center;
  }

  .badge-plus {
    position: relative;
    width: 38px;
    height: 38px;
    z-index: 2;
  }

  .text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 13px;
    position: relative;
  }

  .num {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 40px;
    line-height: 1;
    color: var(--stand-black);
  }

  .heading {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 72px;
    line-height: 1;
    letter-spacing: -1.5px;
    color: var(--stand-black);
    margin: 0;
    transition: opacity 200ms ease-out;
  }

  /* Hover callout: appears in place of the heading, white card with body copy. */
  .callout {
    position: absolute;
    top: 60px; /* sits below the num */
    left: 0;
    width: 100%;
    max-width: 480px;
    background: var(--stand-white);
    border: 3px solid var(--stand-black);
    box-shadow: 5px 6px 0 var(--stand-black);
    padding: 20px 24px;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-6px);
    transition: opacity 220ms ease-out 80ms, transform 220ms ease-out 80ms;
  }

  .callout p {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 18px;
    line-height: 1.3;
    letter-spacing: -0.2px;
    color: var(--stand-black);
    margin: 0;
  }

  .item:hover .heading {
    opacity: 0;
  }

  .item:hover .callout {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 1024px) {
    .heading {
      font-size: 48px;
    }
  }

  /* Accordion: only enabled on touch / narrow viewports. */
</style>

<script>
  // On mobile, items are an accordion. Tap toggles one open at a time.
  const items = document.querySelectorAll<HTMLElement>('.why .item');
  items.forEach((item) => {
    item.addEventListener('click', (e) => {
      if (window.matchMedia('(min-width: 769px)').matches) return; // desktop = hover behavior, no toggle
      e.preventDefault();
      const isOpen = item.getAttribute('aria-expanded') === 'true';
      items.forEach((i) => i.setAttribute('aria-expanded', 'false'));
      if (!isOpen) item.setAttribute('aria-expanded', 'true');
    });
  });
</script>

<style>
  .why-accordion-marker { display: none; }

  @media (max-width: 768px) {
    .strip {
      padding: 20px 20px;
      font-size: 22px;
      line-height: 1.1;
    }

    /* Mobile: linearize — flex column stack. CSS variables fall back to
       overrides below, so no !important needed. */
    .canvas {
      aspect-ratio: auto;
      padding: 36px 20px 60px;
      display: flex;
      flex-direction: column;
      gap: 28px;
    }

    .photo-card {
      position: relative;
      left: auto;
      top: auto;
      width: 100%;
      transform: none;
      aspect-ratio: 4 / 3;
      order: 3;
    }

    .photo-card.photo-2 {
      order: 6;
    }

    .card-back {
      inset: -8px -10px -16px 8px;
    }

    .item {
      position: relative;
      left: auto;
      top: auto;
      width: 100%;
      max-width: none;
      gap: 16px;
    }

    .item:nth-child(3) { order: 1; }
    .item:nth-child(4) { order: 2; }
    .item:nth-child(5) { order: 4; }
    .item:nth-child(6) { order: 5; }

    .badge-wrap {
      width: 40px;
      height: 50px;
    }

    .badge-plus {
      width: 22px;
      height: 22px;
    }

    .num {
      font-size: 24px;
    }

    .heading {
      font-size: 28px;
      line-height: 1.05;
      letter-spacing: -0.3px;
    }

    /* On mobile, the items become an accordion: callout is hidden by default,
       tapping an item opens its callout. One open at a time (JS enforces). */
    .callout {
      position: static;
      transform: none;
      pointer-events: auto;
      padding: 14px 16px;
      box-shadow: 4px 5px 0 var(--stand-black);
      max-width: none;
      width: 100%;
      opacity: 0;
      max-height: 0;
      overflow: hidden;
      margin-top: 0;
      padding-top: 0;
      padding-bottom: 0;
      border-width: 0;
      transition: opacity 220ms ease-out, max-height 280ms ease-out,
                  margin-top 280ms ease-out, padding 280ms ease-out,
                  border-width 280ms ease-out;
    }

    .item[aria-expanded='true'] .callout {
      opacity: 1;
      max-height: 400px;
      margin-top: 16px;
      padding-top: 14px;
      padding-bottom: 14px;
      border-width: 3px;
    }

    .callout p {
      font-size: 14px;
    }

    .item:hover .heading {
      opacity: 1;
    }
  }
</style>

---
// WHY? — single-panel layout: red strip across the top, four numbered items
// stacked on the left, one photo of a Stand kid on the right. Each item shows
// a white callout with body copy on hover (desktop) or tap (mobile).

interface WhyItem {
  num: string;
  heading: string;
  body: string;
  color: string;
}

const items: WhyItem[] = [
  {
    num: '01',
    heading: 'No worksheets. No lectures. Just doing.',
    body: 'Pricing, marketing, planning. Every skill gets learned because they actually have to use it.',
    color: 'var(--stand-mustard)',
  },
  {
    num: '02',
    heading: "Confidence you can't fake or manufacture.",
    body: 'Kids learn to talk about what they built, explain why it’s good, and pitch to real people. That kind of confidence only comes from doing something real.',
    color: 'var(--stand-pink)',
  },
  {
    num: '03',
    heading: "Money clicks differently when it's theirs.",
    body: 'Pricing, profit, saving versus spending. These things actually land when your kid earned the money themselves.',
    color: 'var(--stand-blue)',
  },
  {
    num: '04',
    heading: 'Reward the fails, not just the sales.',
    body: 'Stand is built for when things don’t go perfectly. Because that’s actually where kids grow the most. We don’t paper over the hard stuff.',
    color: 'var(--stand-green)',
  },
];
---

<section class="why">
  <div class="strip"><span>Why STAND?</span></div>

  <div class="content">
    <ul class="items">
      {
        items.map((item) => (
          <li>
            <button type="button" class="item" aria-expanded="false">
              <span class="badge-wrap">
                <span class="badge-shape" style={{ background: item.color }}></span>
                <span class="badge-icon" aria-hidden="true">
                  <span class="bar bar-h"></span>
                  <span class="bar bar-v"></span>
                </span>
              </span>
              <span class="text">
                <span class="num">{item.num}</span>
                <span class="headline">{item.heading}</span>
                <span class="callout"><span class="callout-body">{item.body}</span></span>
              </span>
            </button>
          </li>
        ))
      }
    </ul>

    <div class="photo-card">
      <img class="photo" src="/brand/why-photo-portrait.png" alt="Stand kid in a red Stand cap on a sidewalk" loading="lazy" />
    </div>
  </div>
</section>

<style>
  .why {
    background: var(--stand-cream);
    width: 100%;
  }

  .strip {
    background: var(--stand-red);
    color: var(--stand-white);
    padding: 14px 50px;
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: clamp(11px, 1.148vw, 16px);
    line-height: 1.18;
    letter-spacing: -0.33px;
  }

  .content {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    max-width: calc(var(--container-max) * 0.75);
    margin: 0 auto;
    align-items: stretch;
  }

  .items {
    list-style: none;
    margin: 0 auto;
    padding: clamp(120px, 14vh, 200px) 0;
    max-width: 380px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 28px;
    justify-content: center;
  }

  .item {
    display: flex;
    gap: 18px;
    align-items: flex-start;
    width: 100%;
    background: transparent;
    border: 0;
    padding: 0;
    text-align: left;
    font: inherit;
    color: inherit;
    cursor: pointer;
    position: relative;
  }

  .badge-wrap {
    flex-shrink: 0;
    position: relative;
    width: 36px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .badge-shape {
    position: absolute;
    inset: 0;
    transform: rotate(27.94deg);
    -webkit-mask-image: url('/brand/badge-mask.png');
            mask-image: url('/brand/badge-mask.png');
    -webkit-mask-size: contain;
            mask-size: contain;
    -webkit-mask-repeat: no-repeat;
            mask-repeat: no-repeat;
    -webkit-mask-position: center;
            mask-position: center;
  }

  .badge-icon {
    position: relative;
    width: 19px;
    height: 19px;
    z-index: 2;
  }

  .bar {
    position: absolute;
    background: var(--stand-white);
    border-radius: 1px;
  }

  .bar-h {
    left: 0;
    right: 0;
    top: 50%;
    height: 3px;
    transform: translateY(-50%);
  }

  .bar-v {
    top: 0;
    bottom: 0;
    left: 50%;
    width: 3px;
    transform: translateX(-50%);
    transition: opacity 180ms ease-out;
  }

  .item[aria-expanded='true'] .bar-v {
    opacity: 0;
  }

  .text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 3px;
    position: relative;
  }

  .num {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(9px, 0.7vw, 11px);
    line-height: 1;
    color: var(--stand-black);
  }

  .headline {
    font-family: var(--font-sans);
    font-weight: 400;
    /* Why's numbered items are list headings, not a section headline, so
       they opt out of the global .headline canon (32px) and keep their
       compact menu-list size. Scoped styles outrank the global rule. */
    font-size: clamp(14px, 1.392vw, 20px);
    line-height: 1.1;
    letter-spacing: -0.4px;
    color: var(--stand-black);
  }

  /* Callout expands inline below the heading and pushes items below it down. */
  .callout {
    display: none;
    margin-top: 12px;
    width: 100%;
    max-width: 340px;
    background: var(--stand-white);
    border: 2px solid var(--stand-black);
    box-shadow: 4px 5px 0 var(--stand-black);
    padding: 12px 14px;
    box-sizing: border-box;
  }

  .callout-body {
    display: block;
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 12px;
    line-height: 1.3;
    letter-spacing: -0.2px;
    color: var(--stand-black);
  }

  .item[aria-expanded='true'] .callout {
    display: block;
  }

  .photo-card {
    /* Break out of the capped .content so the photo's right edge always hits
       the viewport's right edge and its width scales with screen width.
       Anchored to the .content (position: relative): left starts at .content's
       horizontal center plus half-gap; right is pushed past .content's right
       edge by (50vw − 50%) so it lands on the viewport edge. */
    position: absolute;
    top: 0;
    bottom: 0;
    left: calc(50% + 20px);
    right: calc(50% - 50vw);
    overflow: hidden;
  }

  .photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 768px) {
    .strip {
      padding: 14px 20px;
      font-size: 14px;
      line-height: 1.1;
    }

    .content {
      grid-template-columns: 1fr;
      gap: 0;
      padding: 24px 20px 0;
      max-width: none;
    }

    .items {
      gap: 20px;
      padding: 0 0 28px;
    }

    .photo-card {
      position: static;
      width: calc(100% + 40px);
      margin-inline: -20px;
      aspect-ratio: 375 / 309;
    }

    .badge-wrap {
      width: 30px;
      height: 36px;
    }

    .badge-icon {
      width: 16px;
      height: 16px;
    }

    .num { font-size: 11px; }

    .headline {
      font-size: 18px;
      line-height: 1.1;
      letter-spacing: -0.3px;
    }

    .callout {
      max-width: none;
    }
  }
</style>

<script>
  // Click any item to expand its callout (one open at a time, both desktop + mobile).
  const items = document.querySelectorAll<HTMLElement>('.why .item');
  items.forEach((item) => {
    item.addEventListener('click', (e) => {
      e.preventDefault();
      const isOpen = item.getAttribute('aria-expanded') === 'true';
      items.forEach((i) => i.setAttribute('aria-expanded', 'false'));
      if (!isOpen) item.setAttribute('aria-expanded', 'true');
    });
  });
</script>

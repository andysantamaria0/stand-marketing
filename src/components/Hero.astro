---
import Header from './Header.astro';

// Hero canvas reproduces Figma desktop 245:5 (1437×871) and mobile 412:69 (375×491).
// Each floating product has separate desktop + mobile positions; CSS variables
// swap them at the 768px breakpoint.
const products = [
  // desktop:  x  y    size  rot
  // mobile:  mx  my   msize mrot
  { name: 'Green Bracelet', file: 'STAND_PNG_GreenBracelet',
    x: 113, y: 106, size: 247, rot: 0,
    mx: 0,  my: 9,   msize: 81, mrot: 0 },
  { name: 'Blue Hat', file: 'STAND_PNG_BlueHat',
    x: 711, y: 102, size: 307, rot: 16.8,
    mx: 177, my: 52, msize: 81, mrot: 16.8 },
  { name: 'Yellow Sticker', file: 'STAND_PNG_YellowSticker',
    x: 1190, y: 128, size: 247, rot: 0,
    mx: 279, my: 0, msize: 81, mrot: 0 },
  { name: 'Cream Mug', file: 'STAND_PNG_CreamMug',
    x: 254, y: 379, size: 299, rot: -14.1,
    mx: 19, my: 162, msize: 81, mrot: -14.1 },
  { name: 'Pink Hoodie', file: 'STAND_PNG_PinkHoodie',
    x: 1001, y: 503, size: 247, rot: 0,
    mx: 267, my: 255, msize: 81, mrot: 0 },
  { name: 'Yellow Plushie', file: 'STAND_PNG_YellowPlushie',
    x: 33, y: 578, size: 247, rot: 0,
    mx: 13, my: 304, msize: 81, mrot: 0 },
  { name: 'Red Cupcake', file: 'STAND_PNG_RedCupcake',
    x: 563, y: 656, size: 247, rot: 0,
    mx: 147, my: 306, msize: 81, mrot: 0 },
];

const HERO_W = 1437;
const HERO_H = 871;
const MOBILE_W = 375;
const MOBILE_H = 491;
const pct = (n: number, base: number) => `${(n / base) * 100}%`;
// Canvas was widened (75% → 95%) to spread the icons further from the lockup.
// Scaling icon sizes down by 75/95 keeps their on-screen size unchanged so the
// composition spreads outward without growing.
const ICON_SCALE = 75 / 95;
---

<section class="hero" aria-labelledby="hero-title">
  <h1 id="hero-title" class="visually-hidden">Build your own thing. For Real.</h1>

  <div class="hero-canvas">
    {
      products.map((p) => (
        <div
          class={`product${p.file === 'STAND_PNG_CreamMug' ? ' top' : ''}`}
          style={{
            '--x': pct(p.x, HERO_W),
            '--y': pct(p.y, HERO_H),
            '--w': pct(p.size * ICON_SCALE, HERO_W),
            '--rot': `${p.rot}deg`,
            '--mx': pct(p.mx, MOBILE_W),
            '--my': pct(p.my, MOBILE_H),
            '--mw': pct(p.msize, MOBILE_W),
            '--mrot': `${p.mrot}deg`,
          }}
          aria-hidden="true"
        >
          <picture>
            <source srcset={`/brand/${p.file}.webp`} type="image/webp" />
            <img src={`/brand/${p.file}.webp`} alt="" loading="eager" />
          </picture>
        </div>
      ))
    }

    <img class="lockup" src="/brand/hero-lockup.webp" alt="" aria-hidden="true" />
  </div>

  <Header />

  <div class="hero-signup">
    <p class="signup-caption">Sign up to our mailing list for<br />news, updates,<br />and special offers!</p>

    <svg
      class="signup-arrow"
      viewBox="0 0 72 118"
      fill="none"
      aria-hidden="true"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        d="M58 6 C 70 42, 62 82, 30 104"
        stroke="currentColor"
        stroke-width="2.4"
        stroke-linecap="round"
      />
      <path
        d="M13 104 L 30 104 L 30 85"
        stroke="currentColor"
        stroke-width="2.4"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>

    <form class="hero-signup-form" id="hero-waitlist-form" aria-label="Email signup" novalidate>
      <div class="hero-signup-box">
        <picture class="signup-card-bg" aria-hidden="true">
          <source srcset="/brand/sticker-card.webp" type="image/webp" />
          <img src="/brand/sticker-card.png" alt="" />
        </picture>
        <input
          type="email"
          name="email"
          id="hero-waitlist-email"
          placeholder="hello@email.com"
          aria-label="Email address"
          autocomplete="email"
          required
        />
        <button type="submit" class="hero-submit">Submit &rarr;</button>
      </div>
    </form>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--stand-cream);
    width: 100%;
    overflow: hidden;
    /* Fill the viewport and vertically center the canvas + signup group so the
       next (yellow) section doesn't peek in and the composition sits balanced. */
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: clamp(16px, 3.5vh, 44px);
    padding: 20px 0;
  }

  /* The canvas is sized off its HEIGHT (not width) so the whole composition plus
     the signup bar always fits inside 100svh. min(62svh, 42vw) lands the product
     cluster at ~64% of the frame width — the same proportion as the Figma mock —
     on both tall laptops and wide short monitors. Width is derived from the
     1437/871 aspect ratio, so the internal product positions never distort. */
  .hero-canvas {
    position: relative;
    aspect-ratio: 1437 / 871;
    height: min(80svh, 55vw);
    max-width: 92%;
    margin: 0 auto;
  }

  .product {
    position: absolute;
    pointer-events: auto;
    cursor: grab;
    touch-action: none;
    aspect-ratio: 1 / 1;
    z-index: 2;
    left: var(--x);
    top: var(--y);
    width: var(--w);
    transform: translate(var(--dx, 0px), var(--dy, 0px)) rotate(var(--rot));
  }

  .product.dragging {
    cursor: grabbing;
  }

  /* Affordance: a quick wiggle (staggered on load, and again on hover) hints
     that the floating products can be grabbed and dragged. Uses the `rotate`
     property so it never clobbers the product's drag `transform`. */
  @keyframes hero-wiggle {
    0%, 100% { rotate: 0deg; }
    25% { rotate: -6deg; }
    55% { rotate: 5deg; }
    80% { rotate: -2.5deg; }
  }

  .product.is-wiggling img,
  .product:hover img {
    animation: hero-wiggle 0.55s ease-in-out;
  }

  @media (prefers-reduced-motion: reduce) {
    .product.is-wiggling img,
    .product:hover img {
      animation: none;
    }
  }

  /* Cream Mug ("World's Best Boss") sits above the other products by default. */
  .product.top {
    z-index: 3;
  }

  .product img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    -webkit-user-drag: none;
    user-select: none;
    pointer-events: none;
  }

  /* Hero lockup ("Build your own thing. For Real.")
     Original Figma frame: 826×720, positioned at left:397, top:98.
     Centered horizontally with a slight rightward offset; sits in upper-middle. */
  .lockup {
    position: absolute;
    left: 32.3%;
    top: 11.25%;
    width: 45.4%;
    height: auto;
    pointer-events: none;
    z-index: 1;
  }

  /* ── Email signup bar ──────────────────────────────────────────────────
     A skewed white "sticker" input with a hard, offset black drop-shadow, a
     handwritten mailing-list caption, and a drawn arrow pointing at the box —
     matching the Figma hero mock. The caption + arrow are absolutely anchored
     to the box's upper-right so they float over the cream without reserving
     layout space. */
  .hero-signup {
    position: relative;
    width: 78%;
    max-width: 1180px;
    margin: 0 auto;
    z-index: 5;
  }

  .signup-caption {
    position: absolute;
    right: 7%;
    bottom: calc(100% + 30px);
    margin: 0;
    text-align: right;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(13px, 1vw, 16px);
    line-height: 1.3;
    color: var(--stand-black);
  }

  .signup-arrow {
    position: absolute;
    right: 1.5%;
    /* Sit just above the bar's top edge. The form box is later in the DOM and
       would otherwise paint over (clip) the arrowhead, so z-index lifts the
       arrow above it. */
    bottom: calc(100% - 6px);
    z-index: 2;
    width: clamp(46px, 4vw, 68px);
    height: auto;
    color: var(--stand-black);
    pointer-events: none;
  }

  .hero-signup-form {
    position: relative;
  }

  /* The skewed white sticker + hard black shadow is the shared brand vector
     (sticker-card), the same asset the Footer signup uses. It's stretched
     (object-fit: fill) to the bar's thin proportions and carries the shadow, so
     no CSS-drawn box is needed. Larger bottom padding lifts the input/submit off
     the vector's bottom shadow band into the white area. */
  .hero-signup-box {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    height: clamp(60px, 5.2vw, 84px);
    /* Vertical padding is in px, NOT %, because % padding resolves against the
       box WIDTH — on a ~1130px-wide, ~78px-tall bar even 2% became ~23px and
       shoved the text up. The small bottom padding lifts both the email and
       Submit just off the vector's shadow band so they read optically centered. */
    padding: 0 4% 6px 5%;
  }

  .signup-card-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .signup-card-bg img {
    width: 100%;
    height: 100%;
    object-fit: fill;
  }

  .hero-signup-box input {
    position: relative;
    z-index: 1;
    flex: 1;
    min-width: 0;
    border: 0;
    background: transparent;
    outline: none;
    text-align: center;
    /* The left box padding + the Submit button on the right make the flex area
       asymmetric; this pulls the centered text back so it reads centered in the
       full bar rather than in the leftover space beside Submit. */
    padding-right: 6%;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(20px, 2.4vw, 34px);
    line-height: 1;
    color: var(--stand-black);
  }

  .hero-signup-box input::placeholder {
    color: var(--stand-black);
    opacity: 1;
  }

  .hero-submit {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    padding-left: 3%;
    white-space: nowrap;
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(15px, 1.4vw, 20px);
    line-height: 1.2;
    letter-spacing: -0.4px;
    text-decoration: underline;
    text-decoration-thickness: 1.5px;
    text-underline-offset: 2px;
    color: var(--stand-black);
    background: transparent;
    border: 0;
    cursor: pointer;
  }

  @media (max-width: 768px) {
    /* Vertical stack: canvas → header CTAs → signup (Header goes static below). */
    .hero {
      min-height: 100svh;
      justify-content: center;
      gap: 20px;
      padding: 20px 0 28px;
    }
    .hero-canvas {
      width: 100%;
      height: auto;
      max-width: var(--container-max);
      aspect-ratio: 375 / 491;
      /* The 375×491 mobile frame reserves an empty band below the products (it
         used to hold the absolute CTAs). Now that the header flows beneath the
         canvas, reclaim that band with a negative margin so the CTAs/signup pull
         up against the composition instead of floating below a gap. A width-
         relative % tracks the band's height across phone widths. */
      margin-bottom: -22%;
    }

    .hero-signup {
      width: 88%;
    }
    /* In flow (not absolute) on mobile so it can't overlap the header CTAs that
       sit just above it: header → caption → bar. */
    .signup-caption {
      position: static;
      right: auto;
      bottom: auto;
      margin: 0 0 10px;
      text-align: center;
      font-size: 12px;
    }
    /* Drop the desktop line breaks so the caption flows on one line on mobile. */
    .signup-caption br {
      display: none;
    }
    /* Arrow reads as clutter at phone width; the caption sits right above the box. */
    .signup-arrow {
      display: none;
    }
    .hero-signup-box {
      height: clamp(54px, 14vw, 66px);
    }
    .hero-signup-box input {
      font-size: clamp(17px, 5vw, 22px);
    }
    .hero-submit {
      font-size: 15px;
    }

    .product {
      left: var(--mx);
      top: var(--my);
      width: var(--mw);
      transform: translate(var(--dx, 0px), var(--dy, 0px)) rotate(var(--mrot));
    }

    /* On mobile the lockup is centered, fits to 82% of width to avoid clipping
       at the right edge from the "For Real." script's italic flourish. */
    .lockup {
      left: 50%;
      top: 9.7%;
      width: 82%;
      transform: translateX(-50%);
    }
  }
</style>

<script>
  // Make the floating hero products draggable (mouse + touch/iPad), drag-only,
  // free-drop — they stay wherever you release them. Each product keeps its
  // CSS left/top anchor + rotation; we only update a translate offset (--dx/--dy),
  // so desktop/mobile layouts and rotations are preserved.
  const products = document.querySelectorAll('.hero .product');
  let topZ = 10;

  products.forEach((el) => {
    let startX = 0;
    let startY = 0;
    let baseDx = 0;
    let baseDy = 0;
    let dragging = false;

    el.addEventListener('pointerdown', (e) => {
      dragging = true;
      el.setPointerCapture(e.pointerId);
      el.classList.add('dragging');
      el.style.zIndex = String(++topZ); // grabbed item jumps to the front
      startX = e.clientX;
      startY = e.clientY;
      baseDx = parseFloat(el.style.getPropertyValue('--dx')) || 0;
      baseDy = parseFloat(el.style.getPropertyValue('--dy')) || 0;
      e.preventDefault();
    });

    el.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      el.style.setProperty('--dx', `${baseDx + (e.clientX - startX)}px`);
      el.style.setProperty('--dy', `${baseDy + (e.clientY - startY)}px`);
    });

    const end = (e) => {
      if (!dragging) return;
      dragging = false;
      el.classList.remove('dragging');
      try { el.releasePointerCapture(e.pointerId); } catch (_) {}
    };

    el.addEventListener('pointerup', end);
    el.addEventListener('pointercancel', end);
  });

  // Affordance: a quick staggered wiggle shortly after load hints the icons are
  // draggable (the CSS also wiggles each one on hover). Skipped for reduced motion.
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    products.forEach((el, i) => {
      window.setTimeout(() => {
        el.classList.add('is-wiggling');
        window.setTimeout(() => el.classList.remove('is-wiggling'), 650);
      }, 450 + i * 90);
    });
  }

  // Hero email signup. Mirrors the Footer's contract: the marketing site does not
  // capture emails itself — submitting (or pressing Enter) hands off to the app's
  // waitlist flow at app.standkids.com, so there's a single source of truth for
  // signups and no duplicate/unauthenticated capture endpoint to maintain.
  const heroForm = document.getElementById('hero-waitlist-form') as HTMLFormElement | null;
  const heroEmail = document.getElementById('hero-waitlist-email') as HTMLInputElement | null;

  // The placeholder is styled like real text; clear it on focus so the field
  // reads as empty and editable, and restore it on blur if nothing was typed.
  heroEmail?.addEventListener('focus', () => { if (heroEmail) heroEmail.placeholder = ''; });
  heroEmail?.addEventListener('blur', () => { if (heroEmail && !heroEmail.value) heroEmail.placeholder = 'hello@email.com'; });

  heroForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    window.location.href = 'https://app.standkids.com';
  });
</script>

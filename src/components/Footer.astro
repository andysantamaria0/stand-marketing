---
// FOOTER — Figma node 202:2993
// Yellow post-it bg. Stand wordmark + tagline + social, email signup tag, 4 columns of links.
// Signup posts to the existing waitlist endpoint on app.standkids.com — same handler the legacy site used.
---

<footer class="footer">
  <div class="inner">
    <div class="brand">
      <img src="/brand/logo.svg" alt="Stand" width="120" />
      <p>STAND&reg; is where kids create, launch, and grow real businesses.</p>
      <div class="social">
        <a href="https://www.instagram.com/buildwithstand" aria-label="Instagram">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="2" width="20" height="20" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
          </svg>
        </a>
        <a href="https://www.tiktok.com/@buildwithstand" aria-label="TikTok">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor">
            <path d="M16 3v3a4 4 0 0 0 4 4v3a7 7 0 0 1-4-1.3V16a5 5 0 1 1-5-5v3a2 2 0 1 0 2 2V3h3z" />
          </svg>
        </a>
      </div>
    </div>

    <div class="right-stack">
      <form
        class="signup"
        id="waitlist-form"
        data-source="footer"
        aria-label="Email signup"
        novalidate
      >
        <div class="signup-card">
          <picture class="signup-bg" aria-hidden="true">
            <source srcset="/brand/sticker-card.webp" type="image/webp" />
            <img src="/brand/sticker-card.png" alt="" />
          </picture>
          <input
            type="email"
            name="email"
            id="waitlist-email"
            placeholder="hello@standkids.com"
            aria-label="Email address"
            required
            autocomplete="email"
          />
          <div class="signup-confirmed" aria-live="polite">
            <svg class="check" viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="5 12 10 17 19 7" />
            </svg>
            <span class="confirmed-text">
              <strong>You&rsquo;re on the waitlist.</strong>
              <em>We&rsquo;ll be in touch soon.</em>
            </span>
          </div>
        </div>
        <a href="https://app.standkids.com" class="signup-btn">Sign Up &rarr;</a>
      </form>
      <p class="signup-status" id="signup-status" role="status" aria-live="polite"></p>
    </div>
  </div>
</footer>

<script>
  // POSTs to the existing stand-app waitlist endpoint (CORS allows standkids.com).
  //
  // The previous version auto-rendered the "you're on the waitlist" confirmation
  // any time a `stand_waitlist_signed_up = '1'` localStorage flag was set. That
  // produced a critical false-positive: anyone who'd ever submitted any email
  // on this device saw the confirmation card forever, and re-submissions with
  // a different email were swallowed because the input was hidden behind the
  // confirmation. Andy hit this on 2026-05-29 — typed a new test email, saw
  // the success message, but nothing landed in Supabase or Klaviyo because the
  // form never actually fired.
  //
  // Fix: the confirmation card only renders after a real POST returns 200.
  // No persistent flag — returning visitors see an empty input again, which is
  // a minor UX downgrade in exchange for guaranteed truthful state. Supabase
  // de-dupes by unique email, so re-submissions are idempotent no-ops.
  const form = document.getElementById('waitlist-form') as HTMLFormElement | null;
  const status = document.getElementById('signup-status');
  const input = document.getElementById('waitlist-email') as HTMLInputElement | null;

  // The placeholder is styled like real text, so it reads as a pre-filled value.
  // Clear it on focus (incl. when the Sign Up button focuses an empty field) so
  // people see an empty, editable field; restore it on blur if still empty.
  input?.addEventListener('focus', () => { if (input) input.placeholder = ''; });
  input?.addEventListener('blur', () => { if (input && !input.value) input.placeholder = 'hello@standkids.com'; });

  // The footer no longer captures emails — the "Sign Up →" control is a plain
  // link to the app (same destination as the "Start Building" link). Pressing
  // Enter in the email field should follow that same path, not POST anywhere.
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    window.location.href = 'https://app.standkids.com';
  });

  // Smooth-scroll all "early-access" links to the footer signup.
  document.querySelectorAll<HTMLAnchorElement>('a[data-scroll="waitlist"]').forEach((a) => {
    a.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.getElementById('waitlist-form');
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'center' });
        setTimeout(() => input?.focus(), 600);
      }
    });
  });
</script>

<style>
  .footer {
    background: var(--stand-postit);
    padding: 40px 0 24px;
    width: 100%;
  }

  .inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 94px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  .right-stack {
    display: flex;
    flex-direction: column;
  }

  .brand img {
    margin-bottom: 16px;
  }

  .brand p {
    font-family: var(--font-sans);
    font-size: clamp(14px, 1.392vw, 20px);
    line-height: 1.4;
    color: var(--stand-black);
    margin: 0 0 28px;
    max-width: 280px;
  }

  .social {
    display: flex;
    gap: 16px;
    color: var(--stand-black);
  }

  /* Form has two pieces: a sticker-card "card" holding the email input, and a
     "Sign Up →" submit button. Desktop puts the button inside the card on the
     right; mobile drops the button below the card as a separate link. */
  .signup {
    position: relative;
    max-width: 849px;
    width: 100%;
    justify-self: end;
  }

  .signup-card {
    position: relative;
    width: 100%;
    aspect-ratio: 849 / 130;
    padding: 32px 60px 42px;
    box-sizing: border-box;
    display: flex;
    align-items: center;
  }

  .signup-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .signup-bg img {
    width: 100%;
    height: 100%;
    object-fit: fill;
  }

  .signup input {
    position: relative;
    z-index: 1;
    flex: 1;
    border: 0;
    background: transparent;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 28px;
    line-height: 1;
    color: var(--stand-black);
    outline: none;
    min-width: 0;
    text-align: center;
    /* Reserve the right ~22% of the input for the absolutely-positioned
       "Sign Up →" button. Without this, the centered placeholder/email
       extends across the full input width and overlaps the button. */
    padding-right: 22%;
  }

  .signup input::placeholder {
    color: var(--stand-black);
    opacity: 1;
  }

  .signup .signup-btn {
    position: absolute;
    z-index: 2;
    right: 7%;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 16px;
    line-height: 1.4;
    letter-spacing: -0.4px;
    text-decoration: underline;
    text-decoration-thickness: 1.5px;
    color: var(--stand-black);
    background: transparent;
    border: 0;
    cursor: pointer;
  }

  /* "You're on the waitlist" confirmation overlay — replaces the input + button
     after a successful submit (and on subsequent visits via localStorage). */
  .signup-confirmed {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: none;
    align-items: center;
    justify-content: center;
    gap: 14px;
    padding: 0 32px;
    text-align: center;
    color: var(--stand-black);
  }

  .signup-confirmed .check {
    flex-shrink: 0;
    color: var(--stand-red);
  }

  .signup-confirmed .confirmed-text {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1.1;
  }

  .signup-confirmed strong {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(18px, 2.088vw, 30px);
    letter-spacing: -0.4px;
  }

  .signup-confirmed em {
    font-family: var(--font-serif);
    font-style: normal;
    font-weight: 400;
    font-size: clamp(12px, 1.113vw, 16px);
    margin-top: 2px;
  }

  .signup.is-confirmed input,
  .signup.is-confirmed > .signup-btn {
    visibility: hidden;
  }

  .signup.is-confirmed .signup-confirmed {
    display: flex;
  }

  .signup-status {
    margin: 12px 0 0;
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--stand-black);
    min-height: 1.2em;
  }

  .signup-status:empty {
    margin: 0;
  }

  @media (max-width: 768px) {
    .footer {
      padding: 36px 0 40px;
    }
    .inner {
      padding: 0 28px;
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .brand img {
      width: 160px;
      height: auto;
    }
    .brand p {
      font-size: 16px;
      max-width: none;
    }
    .signup {
      justify-self: stretch;
      max-width: 100%;
    }
    .signup-card {
      aspect-ratio: 849 / 130;
      padding: 16px 14px 26px;
    }
    .signup input {
      font-size: clamp(16px, 5.1vw, 18px);
      min-width: 0;
      width: 100%;
      padding-right: 0;
    }
    .signup .signup-btn {
      position: static;
      transform: none;
      display: block;
      margin: 14px auto 0;
      font-size: 16px;
      text-align: center;
    }
    .signup-bg img {
      object-fit: fill;
    }
    .signup-confirmed {
      gap: 8px;
      padding: 0 18px;
    }
    .signup-confirmed .check {
      width: 22px;
      height: 22px;
    }
    .signup-confirmed strong {
      font-size: clamp(14px, 5vw, 18px);
      letter-spacing: 0;
    }
    .signup-confirmed em {
      font-size: clamp(10px, 3.8vw, 12px);
    }
  }
</style>

---
// FOOTER — Figma node 202:2993
// Yellow post-it bg. Stand wordmark + tagline + social, email signup tag, 4 columns of links.
// Signup posts to the existing waitlist endpoint on app.standkids.com — same handler the legacy site used.
---

<footer class="footer">
  <div class="inner">
    <div class="top">
      <div class="brand">
        <img src="/brand/logo.svg" alt="Stand" width="120" />
        <p>STAND&reg; is where kids create, launch, and grow real businesses.</p>
        <div class="social">
          <a href="https://www.instagram.com/buildwithstand" aria-label="Instagram">
            <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="2" width="20" height="20" rx="5" />
              <circle cx="12" cy="12" r="4" />
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
            </svg>
          </a>
          <a href="https://www.tiktok.com/@buildwithstand" aria-label="TikTok">
            <svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor">
              <path d="M16 3v3a4 4 0 0 0 4 4v3a7 7 0 0 1-4-1.3V16a5 5 0 1 1-5-5v3a2 2 0 1 0 2 2V3h3z" />
            </svg>
          </a>
        </div>
      </div>

      <form
        class="signup"
        id="waitlist-form"
        data-source="footer"
        aria-label="Email signup"
        novalidate
      >
        <picture class="signup-bg" aria-hidden="true">
          <source srcset="/brand/sticker-card.webp" type="image/webp" />
          <img src="/brand/sticker-card.png" alt="" />
        </picture>
        <input
          type="email"
          name="email"
          id="waitlist-email"
          placeholder="hello@email.com"
          aria-label="Email address"
          required
          autocomplete="email"
        />
        <button type="submit">Sign Up →</button>
      </form>
      <p class="signup-status" id="signup-status" role="status" aria-live="polite"></p>
    </div>

    <nav class="links">
      <div class="col">
        <a href="/faq">FAQ</a>
        <a href="/terms">Terms</a>
        <a href="/privacy">Privacy Policy</a>
      </div>
      <div class="col">
        <a href="#">Policy</a>
        <a href="#">Accessibility</a>
        <a href="#">Privacy Choices</a>
      </div>
      <div class="col">
        <a href="#">About</a>
        <a href="#">Parent Controls</a>
        <a href="#">Use of AI</a>
      </div>
      <div class="col">
        <a href="#">Subscribe</a>
        <a href="https://app.standkids.com">Log In</a>
      </div>
    </nav>
  </div>
</footer>

<script>
  // POSTs to the existing stand-app waitlist endpoint (CORS allows standkids.com).
  const form = document.getElementById('waitlist-form') as HTMLFormElement | null;
  const status = document.getElementById('signup-status');
  const input = document.getElementById('waitlist-email') as HTMLInputElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!input || !status) return;

    const email = input.value.trim();
    if (!email.includes('@')) {
      status.textContent = 'Please enter a valid email.';
      input.focus();
      return;
    }

    const button = form.querySelector('button') as HTMLButtonElement;
    button.disabled = true;
    status.textContent = 'Joining…';

    try {
      const res = await fetch('https://app.standkids.com/api/waitlist', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, source: form.dataset.source || 'footer' }),
      });
      if (!res.ok) throw new Error('Bad status ' + res.status);
      status.textContent = "You're in. We'll be in touch.";
      input.value = '';
      button.textContent = 'You are in';
    } catch (err) {
      status.textContent = "Couldn't sign up just now. Try again in a sec.";
      button.disabled = false;
    }
  });

  // Smooth-scroll all "early-access" links to the footer signup.
  document.querySelectorAll<HTMLAnchorElement>('a[data-scroll="waitlist"]').forEach((a) => {
    a.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.getElementById('waitlist-form');
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'center' });
        setTimeout(() => input?.focus(), 600);
      }
    });
  });
</script>

<style>
  .footer {
    background: var(--stand-postit);
    padding: 60px 0 80px;
    width: 100%;
  }

  .inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 94px;
  }

  .top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    margin-bottom: 60px;
    align-items: start;
  }

  .brand img {
    margin-bottom: 16px;
  }

  .brand p {
    font-family: var(--font-sans);
    font-size: clamp(14px, 1.392vw, 20px);
    line-height: 1.4;
    color: var(--stand-black);
    margin: 0 0 28px;
    max-width: 280px;
  }

  .social {
    display: flex;
    gap: 16px;
    color: var(--stand-black);
  }

  /* Form sits on the same Rectangle 26 PNG used for the "design a brand" sticker.
     The PNG provides the white card + skewed black shadow; we layer inputs on top. */
  .signup {
    position: relative;
    display: flex;
    align-items: center;
    padding: 22px 52px 32px;
    max-width: 849px;
    justify-self: end;
    width: 100%;
    aspect-ratio: 849 / 85;
  }

  .signup-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .signup-bg img {
    width: 100%;
    height: 100%;
    object-fit: fill;
  }

  .signup > input,
  .signup > button {
    position: relative;
    z-index: 1;
  }

  .signup input {
    flex: 1;
    border: 0;
    background: transparent;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(18px, 2.088vw, 30px);
    line-height: 1;
    color: var(--stand-black);
    outline: none;
    min-width: 0;
    text-align: center;
  }

  .signup input::placeholder {
    color: var(--stand-black);
    opacity: 1;
  }

  .signup button {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(16px, 1.740vw, 25px);
    line-height: 1.4;
    letter-spacing: -0.5px;
    text-decoration: underline;
    text-decoration-thickness: 1.5px;
    color: var(--stand-black);
    flex-shrink: 0;
    margin-left: 16px;
  }

  .links {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    padding-top: 0;
  }

  .col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .col a {
    font-family: var(--font-serif);
    font-size: clamp(16px, 1.740vw, 25px);
    line-height: 1.2;
    color: var(--stand-black);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    width: fit-content;
  }

  .signup-status {
    grid-column: 2;
    margin: 12px 0 0;
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--stand-black);
    min-height: 1.2em;
  }

  .signup-status:empty {
    margin: 0;
  }

  @media (max-width: 768px) {
    .footer {
      padding: 48px 0 60px;
    }
    .inner {
      padding: 0 24px;
    }
    .top {
      grid-template-columns: 1fr;
      gap: 32px;
      margin-bottom: 40px;
    }
    .signup {
      justify-self: stretch;
      width: 100%;
      max-width: 100%;
      box-sizing: border-box;
      aspect-ratio: auto;
      padding: 14px 18px 22px;
      min-height: 60px;
    }
    .signup input {
      font-size: 18px;
      min-width: 0;
      width: 100%;
    }
    .signup button {
      font-size: 15px;
      margin-left: 8px;
    }
    .signup-bg img {
      object-fit: fill;
    }
    .links {
      grid-template-columns: 1fr 1fr;
      gap: 28px;
    }
    .col a {
      font-size: 18px;
    }
  }
</style>

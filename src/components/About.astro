---
// ABOUT — Figma node 107:689
// Post-it yellow background. Big black headline sans, white skewed sticker with
// Pie Pie display type that ROTATES through journey phrases (per Faye:
// "text on rotation. itll say one phrase, then the other... no transition motion"),
// then a second headline + red text links.

const stickerPhrases = [
  'build a brand',
  'design products',
  'open a storefront',
  'make sales',
  'learn how money works',
];
---

<section class="about">
  <div class="inner">
    <p class="eyebrow">About Us</p>

    <h2 class="headline">
      STAND is where kids create, launch, and grow real businesses.
    </h2>

    <div class="sticker" id="about-sticker">
      <picture>
        <source srcset="/brand/sticker-card.webp" type="image/webp" />
        <img src="/brand/sticker-card.png" alt="" aria-hidden="true" />
      </picture>
      {
        stickerPhrases.map((phrase, i) => (
          <span class="phrase" data-active={i === 0 ? 'true' : 'false'}>
            {phrase}
          </span>
        ))
      }
    </div>

    <h2 class="headline second">
      STAND is a one of a kind destination, designed for kids. This is the
      modern lemonade stand for the next generation.
    </h2>

    <div class="links">
      <a href="https://app.standkids.com">Start Building →</a>
      <a href="/faq" class="learn-more">Learn More →</a>
    </div>

  </div>
</section>

<script>
  // Rotate the sticker text through the journey phrases every 2.5s.
  // No transition between them — instant swap, per Faye's spec.
  const sticker = document.getElementById('about-sticker');
  if (sticker) {
    const phrases = sticker.querySelectorAll<HTMLElement>('.phrase');
    if (phrases.length > 1) {
      let i = 0;
      setInterval(() => {
        phrases[i].dataset.active = 'false';
        i = (i + 1) % phrases.length;
        phrases[i].dataset.active = 'true';
      }, 2500);
    }
  }
</script>

<style>
  .about {
    background: var(--stand-postit);
    width: 100%;
    box-sizing: border-box;
    padding: clamp(48px, 7vh, 100px) 0;
  }

  .inner {
    max-width: calc(var(--container-max) * 0.75);
    margin: 0 auto;
    padding: 0 70px;
    position: relative;
    container-type: inline-size;
  }

  .eyebrow {
    font-family: var(--font-serif);
    font-weight: 300;
    line-height: 1.18;
    letter-spacing: -0.33px;
    color: var(--stand-black);
    margin: 0 0 clamp(12px, 2.25vh, 45px);
  }

  .headline {
    font-family: var(--font-sans);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.75px;
    color: var(--stand-black);
    margin: 0;
    max-width: 938px;
  }

  .headline.second {
    margin-top: clamp(18px, 3.75vh, 75px);
  }

  .sticker {
    position: relative;
    margin: clamp(15px, 3vh, 45px) auto;
    width: 100%;
    max-width: 928px;
    aspect-ratio: 1237 / 120;
  }

  .sticker img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .sticker .phrase {
    position: absolute;
    inset: 0;
    /* Card sits in roughly the top 85% of the PNG (black shadow under-right). */
    bottom: 18%;
    display: none;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(18px, 2.609vw, 38px);
    line-height: 1;
    color: var(--stand-black);
    text-transform: lowercase;
    letter-spacing: -0.75px;
  }

  .sticker .phrase[data-active='true'] {
    display: flex;
  }

  .links {
    margin-top: clamp(15px, 3vh, 60px);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .links a {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 1.485cqw; /* half of headline (2.97cqw) — 16px max */
    line-height: 1.4;
    letter-spacing: -0.3px;
    color: var(--stand-red);
    text-decoration: underline;
    text-decoration-thickness: 1.5px;
    width: fit-content;
  }

  /* Mobile-only: tilted photo card sits below the links. */
  .links a.learn-more {
    display: none;
  }

  @media (max-width: 768px) {
    .about {
      padding: 36px 0 40px;
      position: relative;
      overflow: hidden;
      min-height: 0;
      display: block;
    }
    .inner {
      padding: 0 20px;
    }
    .eyebrow {
      line-height: 1.18;
      letter-spacing: -0.4px;
      margin: 0 0 20px;
      padding-left: 0;
    }
    .headline {
      line-height: 1.05;
      letter-spacing: -0.3px;
      max-width: none;
      overflow-wrap: break-word;
    }
    .headline.second {
      margin-top: 24px;
    }
    .sticker {
      margin: 22px auto;
      max-width: 305px;
    }
    .sticker .phrase {
      font-size: 16px;
      letter-spacing: -0.3px;
    }
    .links {
      margin-top: 28px;
      gap: 6px;
    }
    .links a {
      font-size: 14px;
      line-height: 1.4;
      letter-spacing: -0.3px;
    }
    .links a.learn-more {
      display: inline-block;
    }

  }
</style>

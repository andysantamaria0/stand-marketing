---
// ABOUT — Figma node 107:689
// Post-it yellow background. Big black headline sans, white skewed sticker with
// Pie Pie display type that ROTATES through journey phrases (per Faye:
// "text on rotation. itll say one phrase, then the other... no transition motion"),
// then a second headline + red text links.

const stickerPhrases = [
  'design a brand',
  'choose products',
  'open a storefront',
  'make sales',
  'learn how money works',
];
---

<section class="about">
  <div class="inner">
    <p class="eyebrow">About Us</p>

    <h2 class="headline">
      STAND is where kids create, launch, and grow real businesses.
    </h2>

    <div class="sticker" id="about-sticker">
      <picture>
        <source srcset="/brand/sticker-card.webp" type="image/webp" />
        <img src="/brand/sticker-card.png" alt="" aria-hidden="true" />
      </picture>
      {
        stickerPhrases.map((phrase, i) => (
          <span class="phrase" data-active={i === 0 ? 'true' : 'false'}>
            {phrase}
          </span>
        ))
      }
    </div>

    <h2 class="headline second">
      STAND is a one of a kind destination, designed for kids.<br />
      This is the modern lemonade stand for the next generation.
    </h2>

    <div class="links">
      <a href="https://app.standkids.com">Start Building →</a>
      <a href="#">Learn More →</a>
    </div>

    <picture class="mobile-photo" aria-hidden="true">
      <source srcset="/brand/why-photo-2.webp" type="image/webp" />
      <img src="/brand/why-photo-2.webp" alt="" loading="lazy" />
    </picture>
  </div>
</section>

<script>
  // Rotate the sticker text through the journey phrases every 2.5s.
  // No transition between them — instant swap, per Faye's spec.
  const sticker = document.getElementById('about-sticker');
  if (sticker) {
    const phrases = sticker.querySelectorAll<HTMLElement>('.phrase');
    if (phrases.length > 1) {
      let i = 0;
      setInterval(() => {
        phrases[i].dataset.active = 'false';
        i = (i + 1) % phrases.length;
        phrases[i].dataset.active = 'true';
      }, 2500);
    }
  }
</script>

<style>
  .about {
    background: var(--stand-postit);
    width: 100%;
    padding: 93px 0 100px;
  }

  .inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 94px;
    position: relative;
  }

  .eyebrow {
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: clamp(20px, 2.784vw, 40px);
    line-height: 1.18;
    letter-spacing: -0.8px;
    color: var(--stand-black);
    margin: 0 0 60px;
  }

  .headline {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(36px, 4.524vw, 65px);
    line-height: 1;
    letter-spacing: -1.5px;
    color: var(--stand-black);
    margin: 0;
    max-width: 1250px;
  }

  .headline.second {
    margin-top: 100px;
  }

  .sticker {
    position: relative;
    margin: 60px auto;
    width: 100%;
    max-width: 1237px;
    aspect-ratio: 1237 / 120;
  }

  .sticker img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .sticker .phrase {
    position: absolute;
    inset: 0;
    /* Card sits in roughly the top 85% of the PNG (black shadow under-right). */
    bottom: 18%;
    display: none;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(24px, 3.479vw, 50px);
    line-height: 1;
    color: var(--stand-black);
    text-transform: lowercase;
    letter-spacing: -1px;
  }

  .sticker .phrase[data-active='true'] {
    display: flex;
  }

  .links {
    margin-top: 80px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .links a {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(16px, 1.740vw, 25px);
    line-height: 1.4;
    letter-spacing: -0.5px;
    color: var(--stand-red);
    text-decoration: underline;
    text-decoration-thickness: 1.5px;
    width: fit-content;
  }

  /* Hide the mobile photo on desktop. */
  .mobile-photo,
  .mobile-photo img {
    display: none;
  }

  @media (max-width: 768px) {
    .about {
      padding: 36px 0 0;
      position: relative;
      overflow: hidden;
    }
    .inner {
      padding: 0 20px;
    }
    .eyebrow {
      font-size: 9.44px;
      line-height: 11.092px;
      letter-spacing: -0.1888px;
      margin: 0 0 12px;
      padding-left: 18px;
    }
    .headline {
      font-size: 20px;
      line-height: 1.05;
      letter-spacing: -0.3px;
      max-width: none;
      overflow-wrap: break-word;
    }
    .headline.second {
      margin-top: 24px;
    }
    .sticker {
      margin: 22px auto;
      max-width: 305px;
    }
    .sticker .phrase {
      font-size: 16px;
      letter-spacing: -0.3px;
    }
    .links {
      margin-top: 28px;
    }
    .links a {
      font-size: 15px;
      line-height: 1.4;
      letter-spacing: -0.3px;
    }

    /* happy-teenagers photo, mobile only — sits at the bottom of About with
       a slight rotation, matching the Figma mobile frame. */
    .mobile-photo {
      display: block;
      position: relative;
      width: 322px;
      max-width: 100%;
      margin: 36px auto 0;
      aspect-ratio: 322 / 246;
      transform: rotate(4.54deg);
      transform-origin: center;
    }
    .mobile-photo img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }
</style>

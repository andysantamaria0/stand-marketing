---
// FIND YOUR BUSINESS — Figma node 107:744 (1437×2277)
// Cream bg. Eyebrow + headline + 6 colored organic silhouettes scattered with
// black skewed numbered tags. Hover state (node 112:116) shows white callout cards.

// On hover: silhouette stays, real product photo fades in over it,
// and a white callout card slides in next to it.

interface Business {
  num: number;
  name: string;
  desc: string;
  svg: string;     // silhouette (default state)
  photo: string;   // real product image (revealed on hover)
  // Silhouette position + size, in raw Figma px relative to 1437×2277 frame
  sx: number; sy: number; sw: number; sh: number;
  // Number-tag absolute position, raw Figma px
  nx: number; ny: number;
  // Callout card offset relative to silhouette (for hover state)
  calloutSide: 'left' | 'right';
}

const HERO_W = 1437;
const HERO_H = 2277;
const pct = (n: number, base: number) => `${(n / base) * 100}%`;

const items: Business[] = [
  {
    num: 1, name: 'hats',
    desc: 'Small bio here about the hats you can design.',
    svg: 'STAND_SVG_BlueHat_Silhouette',
    photo: 'STAND_PNG_BlueHat',
    sx: 320, sy: 290, sw: 700, sh: 450,
    nx: 473, ny: 409,
    calloutSide: 'right',
  },
  {
    num: 2, name: 'baked goods',
    desc: 'Cupcakes, cookies, and treats with your own brand.',
    svg: 'STAND_SVG_RedCupcake_Silhouette',
    photo: 'STAND_PNG_RedCupcake',
    sx: 1010, sy: 350, sw: 400, sh: 720,
    nx: 1134, ny: 549,
    calloutSide: 'left',
  },
  {
    num: 3, name: 'stickers & art',
    desc: 'Create sticker packs, cards, prints, and custom designs.',
    svg: 'STAND_SVG_YellowSticker_Silhouette',
    photo: 'STAND_PNG_YellowSticker',
    sx: 60, sy: 770, sw: 500, sh: 480,
    nx: 292, ny: 877,
    calloutSide: 'right',
  },
  {
    num: 4, name: 'lifestyle',
    desc: 'Make merch that fits your vibe.',
    svg: 'STAND_SVG_YellowPlushie_Silhouette',
    photo: 'STAND_PNG_YellowPlushie',
    sx: 400, sy: 1000, sw: 540, sh: 540,
    nx: 514, ny: 1037,
    calloutSide: 'right',
  },
  {
    num: 5, name: 'clothes & apparel',
    desc: 'Create hoodies, hats, tees, and other products with your own logo.',
    svg: 'STAND_SVG_PinkHoodie_Silhouette',
    photo: 'STAND_PNG_PinkHoodie',
    sx: 760, sy: 1380, sw: 580, sh: 700,
    nx: 779, ny: 1562,
    calloutSide: 'left',
  },
  {
    num: 6, name: 'jewelry',
    desc: 'Bracelets, charms, and accessories.',
    svg: 'STAND_SVG_GreenBracelet_Silhouette',
    photo: 'STAND_PNG_GreenBracelet',
    sx: 60, sy: 1750, sw: 700, sh: 480,
    nx: 112, ny: 2012,
    calloutSide: 'right',
  },
];
---

<section class="find-business">
  <div class="header-inner">
    <p class="eyebrow">Find Your Business</p>
    <h2 class="headline">Explore business ideas kids can actually imagine building.</h2>
  </div>

  <div class="canvas" style={{ aspectRatio: `${HERO_W} / ${HERO_H}` }}>
    {
      items.map((item) => (
        <div
          class="biz"
          style={{
            left: pct(item.sx, HERO_W),
            top: pct(item.sy, HERO_H),
            width: pct(item.sw, HERO_W),
            height: pct(item.sh, HERO_H),
          }}
        >
          <img class="silhouette" src={`/brand/${item.svg}.svg`} alt={item.name} />
          <img class="photo" src={`/brand/${item.photo}.webp`} alt="" aria-hidden="true" loading="lazy" />

          <div class={`callout ${item.calloutSide}`}>
            <h3>{item.name}</h3>
            <p>{item.desc}</p>
          </div>
        </div>
      ))
    }

    {
      items.map((item) => (
        <span
          class="badge"
          style={{ left: pct(item.nx, HERO_W), top: pct(item.ny, HERO_H) }}
        >
          {item.num}
        </span>
      ))
    }
  </div>
</section>

<script>
  // On mobile, tap a biz card to swap silhouette → real product photo.
  // Desktop uses hover (no JS needed).
  const cards = document.querySelectorAll<HTMLElement>('.find-business .biz');
  cards.forEach((card) => {
    card.addEventListener('click', () => {
      if (window.matchMedia('(min-width: 769px)').matches) return;
      const wasOpen = card.classList.contains('is-open');
      cards.forEach((c) => c.classList.remove('is-open'));
      if (!wasOpen) card.classList.add('is-open');
    });
  });
</script>

<script>
  // Mobile: tap a card to swap silhouette → real product photo. One open at a time.
  // Desktop uses the existing hover CSS — JS is a no-op there.
  const cards = document.querySelectorAll<HTMLElement>('.find-business .biz');
  cards.forEach((card) => {
    card.addEventListener('click', () => {
      if (window.matchMedia('(min-width: 769px)').matches) return;
      const wasOpen = card.classList.contains('is-open');
      cards.forEach((c) => c.classList.remove('is-open'));
      if (!wasOpen) card.classList.add('is-open');
    });
  });
</script>

<style>
  .find-business {
    background: var(--stand-cream);
    padding: 93px 0 100px;
    width: 100%;
  }

  .header-inner {
    max-width: var(--container-max);
    margin: 0 auto 60px;
    padding: 0 94px;
  }

  .eyebrow {
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: 40px;
    line-height: 47px;
    letter-spacing: -0.8px;
    color: var(--stand-black);
    margin: 0 0 32px;
  }

  .headline {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 78px;
    line-height: 1;
    letter-spacing: -1.5px;
    color: var(--stand-black);
    margin: 0;
    max-width: 1250px;
  }

  .canvas {
    position: relative;
    width: 100%;
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .biz {
    position: absolute;
    cursor: pointer;
  }

  .silhouette,
  .photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: opacity 280ms ease-out, transform 280ms ease-out;
  }

  /* Product photos ship as square PNGs with whitespace around the product.
     Silhouettes ship as tight-cropped SVGs. Scale photos up so they render
     at the same visual size as their silhouette pair. */
  .photo {
    transform: scale(1.35);
    opacity: 0;
    pointer-events: none;
  }

  .biz {
    /* Allow the scaled-up hover photo to spill past the silhouette bounds. */
    overflow: visible;
  }

  .biz:hover .silhouette {
    opacity: 0;
  }

  .biz:hover .photo {
    opacity: 1;
  }

  /* Black organic-blob number tag — uses the same Rectangle22 mask shape as Figma */
  .badge {
    position: absolute;
    width: 137px;
    height: 140px;
    color: var(--stand-white);
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 50px;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 5;
    transform: translate(-50%, -50%);
  }

  .badge::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--stand-black);
    transform: rotate(27.94deg);
    -webkit-mask-image: url('/brand/badge-mask.png');
            mask-image: url('/brand/badge-mask.png');
    -webkit-mask-size: contain;
            mask-size: contain;
    -webkit-mask-repeat: no-repeat;
            mask-repeat: no-repeat;
    -webkit-mask-position: center;
            mask-position: center;
    z-index: -1;
  }

  /* Callout: hidden by default, slides in on hover of parent .biz */
  .callout {
    position: absolute;
    top: 35%;
    background: var(--stand-white);
    border: 3px solid var(--stand-black);
    box-shadow: 5px 7px 0 var(--stand-black);
    padding: 24px 28px;
    min-width: 280px;
    max-width: 380px;
    z-index: 8;
    opacity: 0;
    pointer-events: none;
    transition: opacity 220ms ease-out 60ms, transform 220ms ease-out 60ms;
  }

  .callout.right {
    left: 85%;
    transform: translateX(-12px);
  }
  .callout.left {
    right: 85%;
    transform: translateX(12px);
  }

  .biz:hover .callout {
    opacity: 1;
    transform: translateX(0);
  }

  .callout h3 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 40px;
    line-height: 1;
    color: var(--stand-black);
    margin: 0 0 12px;
  }

  .callout p {
    font-family: var(--font-sans);
    font-size: 18px;
    line-height: 1.3;
    color: var(--stand-black);
    margin: 0;
  }

  @media (max-width: 768px) {
    .find-business {
      padding: 36px 0 60px;
    }
    .header-inner {
      padding: 0 20px;
      margin-bottom: 28px;
    }
    .eyebrow {
      font-size: 9.44px;
      line-height: 11.092px;
      letter-spacing: -0.1888px;
      margin: 0 0 10px;
    }
    .headline {
      font-size: 20px;
      line-height: 1;
      letter-spacing: -0.3px;
    }

    /* Mobile = vertical card list. Each card: skewed number tag on the left edge,
       silhouette overlapping the card's left side, name + description in the body.
       Tap a card → silhouette swaps to the real product photo. */
    .canvas {
      aspect-ratio: auto;
      display: flex;
      flex-direction: column;
      gap: 24px;
      padding: 0 20px;
    }
    .canvas > .badge {
      display: none;
    }
    .biz {
      position: relative;
      left: auto !important;
      top: auto !important;
      width: 100% !important;
      height: auto !important;
      min-height: 110px;
      padding: 18px 20px 18px 110px;
      background: var(--stand-white);
      border: 2.5px solid var(--stand-black);
      box-shadow: 4px 5px 0 var(--stand-black);
      cursor: pointer;
      display: block;
      overflow: visible;
    }
    .biz::before {
      content: counter(biz);
      counter-increment: biz;
      position: absolute;
      left: -10px;
      top: 14px;
      width: 38px;
      height: 38px;
      background: var(--stand-black);
      color: var(--stand-white);
      font-family: var(--font-serif);
      font-size: 22px;
      display: flex;
      align-items: center;
      justify-content: center;
      transform: rotate(8deg);
      z-index: 4;
    }
    .canvas { counter-reset: biz; }

    .silhouette,
    .photo {
      position: absolute;
      left: 8px;
      top: 50%;
      transform: translateY(-50%);
      width: 96px;
      height: 96px;
      object-fit: contain;
      z-index: 3;
      transition: opacity 220ms ease-out;
    }

    .photo {
      opacity: 0;
      transform: translateY(-50%) scale(1.05);
    }

    .biz.is-open .silhouette {
      opacity: 0;
    }
    .biz.is-open .photo {
      opacity: 1;
    }

    .callout {
      position: static;
      transform: none;
      opacity: 1;
      background: transparent;
      border: 0;
      box-shadow: none;
      padding: 0;
      min-width: 0;
      max-width: none;
      pointer-events: none;
    }
    .callout h3 {
      font-size: 22px;
      line-height: 1;
      margin: 0 0 6px;
    }
    .callout p {
      font-size: 13px;
      line-height: 1.3;
    }
  }
</style>

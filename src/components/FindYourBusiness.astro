---
// FIND YOUR BUSINESS — Figma node 107:744 (1437×1083, redesign 2026-05-26).
// Cream frame with a white panel across the bottom. Eyebrow + headline, a
// horizontal row of 6 product silhouettes, and a shared prompt that defaults to
// "hover over an item / to learn more about our Product Lab." and swaps to the
// hovered item's name + bio. On hover the silhouette becomes the real photo.
// Type scales with the frame (cqw) so it stays proportional below 1437px.

interface Business {
  name: string;
  desc: string;
  svg: string;   // silhouette (default)
  photo: string; // real product image (revealed on hover)
  // bounding box in raw Figma px, relative to the 1437×1083 frame
  sx: number; sy: number; sw: number; sh: number;
  z: number; // stacking order (higher = front)
}

const HERO_W = 1437;
const HERO_H = 1083;
const pct = (n: number, base: number) => `${(n / base) * 100}%`;

const DEFAULT_TITLE = 'hover over an item';
const DEFAULT_DESC = 'to learn more about our Product Lab.';

const items: Business[] = [
  { name: 'hats', desc: 'Design custom hats of your own creation.',
    svg: 'STAND_SVG_BlueHat_Silhouette', photo: 'STAND_PNG_BlueHat',
    sx: 83, sy: 203, sw: 439, sh: 439, z: 4 },
  { name: 'stickers & art', desc: 'Create sticker packs, cards, prints, and custom designs.',
    svg: 'STAND_SVG_YellowSticker_Silhouette', photo: 'STAND_PNG_YellowSticker',
    sx: 228, sy: 397, sw: 367, sh: 367, z: 2 },
  { name: 'jewelry', desc: 'Make bracelets, charms and accessories with your own style.',
    svg: 'STAND_SVG_GreenBracelet_Silhouette', photo: 'STAND_PNG_GreenBracelet',
    sx: 452, sy: 289, sw: 305, sh: 305, z: 6 },
  { name: 'baked goods', desc: 'Cookies, cupcakes and other treats with your own brand.',
    svg: 'STAND_SVG_RedCupcake_Silhouette', photo: 'STAND_PNG_RedCupcake',
    sx: 596, sy: 340, sw: 379, sh: 379, z: 5 },
  { name: 'collectibles', desc: 'Create fun collectible products like plushies and slime.',
    svg: 'STAND_SVG_YellowPlushie_Silhouette', photo: 'STAND_PNG_YellowPlushie',
    sx: 813, sy: 252, sw: 384, sh: 384, z: 1 },
  { name: 'clothes & apparel', desc: 'Create hoodies, tees, and other products with your own designs.',
    svg: 'STAND_SVG_PinkHoodie_Silhouette', photo: 'STAND_PNG_PinkHoodie',
    sx: 1005, sy: 305, sw: 393, sh: 393, z: 3 },
];
---

<section class="find-business">
  <div class="frame">
    <div class="panel" aria-hidden="true"></div>

    <div class="header-inner">
      <p class="eyebrow">Find Your Business</p>
      <h2 class="headline">Explore business ideas kids can actually imagine building.</h2>
    </div>

    {
      items.map((item, i) => (
        <button
          class="biz"
          type="button"
          data-name={item.name}
          data-desc={item.desc}
          data-num={String(i + 1)}
          aria-label={item.name}
          style={{
            left: pct(item.sx, HERO_W),
            top: pct(item.sy, HERO_H),
            width: pct(item.sw, HERO_W),
            height: pct(item.sh, HERO_H),
            zIndex: item.z,
          }}
        >
          <img class="silhouette" src={`/brand/${item.svg}.svg`} alt={item.name} />
          <img class="photo" src={`/brand/${item.photo}.webp`} alt="" aria-hidden="true" loading="lazy" />
          <span class="biz-label"><strong>{item.name}</strong><em>{item.desc}</em></span>
        </button>
      ))
    }

    <div class="prompt" data-default-title={DEFAULT_TITLE} data-default-desc={DEFAULT_DESC}>
      <h3 class="prompt-title">{DEFAULT_TITLE}</h3>
      <p class="prompt-desc">{DEFAULT_DESC}</p>
    </div>
  </div>
</section>

<script>
  const section = document.querySelector('.find-business');
  if (section) {
    const prompt = section.querySelector('.prompt');
    const titleEl = prompt?.querySelector('.prompt-title');
    const descEl = prompt?.querySelector('.prompt-desc');
    const defTitle = prompt?.getAttribute('data-default-title') ?? '';
    const defDesc = prompt?.getAttribute('data-default-desc') ?? '';
    const isDesktop = () => window.matchMedia('(min-width: 769px)').matches;
    const cards = section.querySelectorAll('.biz');

    cards.forEach((card) => {
      card.addEventListener('pointerenter', () => {
        if (!isDesktop() || !titleEl || !descEl) return;
        card.classList.add('active');
        titleEl.textContent = card.getAttribute('data-name');
        descEl.textContent = card.getAttribute('data-desc');
      });
      card.addEventListener('pointerleave', () => {
        if (!isDesktop() || !titleEl || !descEl) return;
        card.classList.remove('active');
        titleEl.textContent = defTitle;
        descEl.textContent = defDesc;
      });
      // Mobile: tap a card to reveal the product photo (one open at a time).
      card.addEventListener('click', () => {
        if (isDesktop()) return;
        const open = card.classList.contains('is-open');
        cards.forEach((c) => c.classList.remove('is-open'));
        if (!open) card.classList.add('is-open');
      });
    });
  }
</script>

<style>
  .find-business {
    background: var(--stand-cream);
    width: 100%;
  }

  .frame {
    position: relative;
    width: 100%;
    max-width: var(--container-max);
    margin: 0 auto;
    aspect-ratio: 1437 / 1083;
    container-type: inline-size;
  }

  /* White panel across the bottom third (Figma rect 453:137). */
  .panel {
    position: absolute;
    left: 0;
    right: 0;
    top: 70%;
    bottom: 0;
    background: var(--stand-white);
    z-index: 0;
  }

  .header-inner {
    position: absolute;
    top: 7%;
    left: 6.5%;
    right: 6.5%;
    z-index: 3;
  }

  .eyebrow {
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: 1.531cqw; /* 22px @1437 */
    line-height: 1.18;
    letter-spacing: -0.04em;
    color: var(--stand-black);
    margin: 0 0 1.4cqw;
  }

  .headline {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 3.341cqw; /* 48px @1437 */
    line-height: 1;
    letter-spacing: -0.022em;
    color: var(--stand-black);
    margin: 0;
    max-width: none;
  }

  .biz {
    position: absolute;
    z-index: 2;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    appearance: none;
  }

  .silhouette,
  .photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: opacity 260ms ease-out;
  }

  /* Photos are square PNGs with padding; scale up to match the tight silhouette. */
  .photo {
    transform: scale(1.35);
    opacity: 0;
    pointer-events: none;
  }

  .biz:hover .silhouette,
  .biz.active .silhouette {
    opacity: 0;
  }
  .biz:hover .photo,
  .biz.active .photo {
    opacity: 1;
  }

  /* Per-item label is desktop-hidden (shown only in the mobile list). */
  .biz-label {
    display: none;
  }

  /* Shared prompt on the white panel. */
  .prompt {
    position: absolute;
    left: 6%;
    right: 6%;
    top: 80%;
    text-align: center;
    z-index: 2;
  }

  .prompt-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 2.296cqw; /* 33px @1437 */
    line-height: 1.1;
    color: var(--stand-black);
    margin: 0 0 0.8cqw;
  }

  .prompt-desc {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.113cqw; /* 16px @1437 */
    line-height: 1.3;
    letter-spacing: -0.02em;
    color: var(--stand-black);
    margin: 0;
  }

  @media (max-width: 768px) {
    .find-business {
      padding: 36px 0 56px;
    }

    /* Mobile = vertical card list: number, silhouette, name + bio. */
    .frame {
      aspect-ratio: auto;
      max-width: none;
      display: flex;
      flex-direction: column;
      gap: 20px;
      padding: 0 20px;
    }
    .panel { display: none; }

    .header-inner {
      position: static;
      left: auto;
      right: auto;
      top: auto;
      margin-bottom: 8px;
    }
    .eyebrow { font-size: 13px; margin: 0 0 8px; }
    .headline { font-size: 24px; max-width: none; }

    .biz {
      position: relative;
      left: auto !important;
      top: auto !important;
      width: 100% !important;
      height: auto !important;
      min-height: 104px;
      padding: 16px 18px 16px 104px;
      background: var(--stand-white);
      border: 2.5px solid var(--stand-black);
      box-shadow: 4px 5px 0 var(--stand-black);
      text-align: left;
      display: block;
    }
    .biz::before {
      content: attr(data-num);
      position: absolute;
      left: -10px;
      top: 12px;
      width: 36px;
      height: 36px;
      background: var(--stand-black);
      color: var(--stand-white);
      font-family: var(--font-serif);
      font-size: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      transform: rotate(8deg);
      z-index: 4;
    }

    .silhouette,
    .photo {
      position: absolute;
      inset: auto;
      left: 6px;
      top: 50%;
      transform: translateY(-50%);
      width: 90px;
      height: 90px;
      z-index: 3;
    }
    .photo { transform: translateY(-50%) scale(1.05); }
    .biz.is-open .silhouette { opacity: 0; }
    .biz.is-open .photo { opacity: 1; }

    .biz-label {
      display: block;
    }
    .biz-label strong {
      display: block;
      font-family: var(--font-display);
      font-weight: 400;
      font-size: 22px;
      line-height: 1;
      margin-bottom: 6px;
    }
    .biz-label em {
      font-family: var(--font-sans);
      font-style: normal;
      font-size: 13px;
      line-height: 1.3;
      color: var(--stand-black);
    }

    .prompt { display: none; }
  }
</style>

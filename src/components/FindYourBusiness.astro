---
// FIND YOUR BUSINESS — Figma node 653:322 (1437×630, redesign 2026-06-22).
// Cream section. Eyebrow + headline, then a horizontal row of 6 product
// silhouettes — three of them tilted (hat, sticker, plushie) per the design.
// On hover the silhouette becomes the real photo and a label (name +
// description) appears directly beneath that item — no shared prompt, nothing
// shown by default. Assets share a uniform 3000×3000 canvas, so photo and
// silhouette register exactly (no per-item scale). Each item is positioned by
// its centre + art size + rotation so the tilt pivots in place. Type scales
// with the frame (cqw) so it stays proportional below 1437px.

interface Business {
  name: string;
  desc: string;
  svg: string;   // silhouette (default)
  photo: string; // real product image (revealed on hover)
  // Centre point + square art size (raw Figma px, relative to the 1437×630
  // frame) + rotation in degrees. Centre-based so the tilt pivots in place.
  cx: number; cy: number; aw: number; rot: number;
  z: number; // stacking order (higher = front)
  // Hover label box in raw Figma px (relative to the frame); text is centred.
  lx: number; ly: number; lw: number;
  // Mobile coords (top-left), relative to MOBILE_W × MOBILE_H portrait frame.
  mx: number; my: number; mw: number; mh: number;
}

const HERO_W = 1437;
const HERO_H = 630;
const MOBILE_W = 375;
const MOBILE_H = 513;
const pct = (n: number, base: number) => `${(n / base) * 100}%`;

const items: Business[] = [
  { name: 'hats', desc: 'Design custom hats of your own creation.',
    svg: 'STAND_SVG_BlueHat_Silhouette', photo: 'STAND_PNG_BlueHat',
    cx: 209.44, cy: 339.44, aw: 307.10, rot: 23.56, z: 6,
    lx: 63, ly: 451, lw: 214,
    mx: 91, my: 117, mw: 163, mh: 100 },
  { name: 'stickers & art', desc: 'Create sticker packs, cards, prints, and custom designs.',
    svg: 'STAND_SVG_YellowSticker_Silhouette', photo: 'STAND_PNG_YellowSticker',
    cx: 424.52, cy: 307.52, aw: 254.36, rot: -4.87, z: 5,
    lx: 273, ly: 471, lw: 279,
    mx: -6, my: 198, mw: 124, mh: 123 },
  { name: 'jewelry', desc: 'Make bracelets, charms, and accessories with your own style.',
    svg: 'STAND_SVG_GreenBracelet_Silhouette', photo: 'STAND_PNG_GreenBracelet',
    cx: 641.08, cy: 308.08, aw: 228.16, rot: 0, z: 2,
    lx: 480, ly: 466, lw: 279,
    mx: -2, my: 358, mw: 155, mh: 106 },
  { name: 'baked goods', desc: 'Cookies, cupcakes, and other treats with your own brand.',
    svg: 'STAND_SVG_RedCupcake_Silhouette', photo: 'STAND_PNG_RedCupcake',
    cx: 860.01, cy: 342.01, aw: 284.02, rot: 0, z: 1,
    lx: 704, ly: 500, lw: 279,
    mx: 264, my: 108, mw: 88, mh: 150 },
  { name: 'collectibles', desc: 'Create fun collectible products like plushies or slime.',
    svg: 'STAND_SVG_YellowPlushie_Silhouette', photo: 'STAND_PNG_YellowPlushie',
    cx: 1068.65, cy: 301.65, aw: 254.36, rot: -8, z: 4,
    lx: 906, ly: 489, lw: 279,
    mx: 118, my: 231, mw: 125, mh: 116 },
  { name: 'clothes & apparel', desc: 'Create hoodies, tees, and other products with your own design.',
    svg: 'STAND_SVG_PinkHoodie_Silhouette', photo: 'STAND_PNG_PinkHoodie',
    cx: 1269.01, cy: 321.01, aw: 294.03, rot: 0, z: 3,
    lx: 1030, ly: 490, lw: 407,
    mx: 180, my: 293, mw: 176, mh: 179 },
];
---

<section class="find-business">
  <div class="frame">
    <div class="header-inner">
      <p class="eyebrow">Find Your Business</p>
      <h2 class="headline">Explore business ideas kids can actually imagine building.</h2>
    </div>

    {
      items.map((item) => (
        <button
          class="biz"
          type="button"
          data-name={item.name}
          data-desc={item.desc}
          data-lx={pct(item.lx, HERO_W)}
          data-ly={pct(item.ly, HERO_H)}
          data-lw={pct(item.lw, HERO_W)}
          aria-label={item.name}
          style={{
            '--cx': pct(item.cx, HERO_W),
            '--cy': pct(item.cy, HERO_H),
            '--w': pct(item.aw, HERO_W),
            '--h': pct(item.aw, HERO_H),
            '--rot': `${item.rot}deg`,
            '--mx': pct(item.mx, MOBILE_W),
            '--my': pct(item.my, MOBILE_H),
            '--mw': pct(item.mw, MOBILE_W),
            '--mh': pct(item.mh, MOBILE_H),
            zIndex: item.z,
          }}
        >
          <img class="silhouette" src={`/brand/${item.svg}.svg`} alt={item.name} />
          <img class="photo" src={`/brand/${item.photo}.webp`} alt="" aria-hidden="true" loading="lazy" />
        </button>
      ))
    }

    <div class="label" aria-hidden="true">
      <h3 class="label-title"></h3>
      <p class="label-desc"></p>
    </div>
  </div>
</section>

<script>
  const section = document.querySelector('.find-business');
  if (section) {
    const label = section.querySelector('.label') as HTMLElement | null;
    const titleEl = label?.querySelector('.label-title');
    const descEl = label?.querySelector('.label-desc');
    const isDesktop = () => window.matchMedia('(min-width: 769px)').matches;
    const cards = section.querySelectorAll('.biz');

    const show = (card: Element) => {
      if (!label || !titleEl || !descEl) return;
      titleEl.textContent = card.getAttribute('data-name');
      descEl.textContent = card.getAttribute('data-desc');
      label.style.left = card.getAttribute('data-lx') ?? '';
      label.style.top = card.getAttribute('data-ly') ?? '';
      label.style.width = card.getAttribute('data-lw') ?? '';
      label.classList.add('is-visible');
    };
    const hide = () => label?.classList.remove('is-visible');

    cards.forEach((card) => {
      card.addEventListener('pointerenter', () => {
        if (!isDesktop()) return;
        card.classList.add('active');
        show(card);
      });
      card.addEventListener('pointerleave', () => {
        if (!isDesktop()) return;
        card.classList.remove('active');
        hide();
      });
      // Mobile: tap to reveal the product photo + label (one open at a time).
      card.addEventListener('click', () => {
        if (isDesktop()) return;
        const wasActive = card.classList.contains('active');
        cards.forEach((c) => c.classList.remove('active'));
        if (!wasActive) {
          section.classList.add('has-active');
          card.classList.add('active');
          show(card);
        } else {
          section.classList.remove('has-active');
          hide();
        }
      });
    });
  }
</script>

<style>
  .find-business {
    position: relative;
    background: var(--stand-cream);
    width: 100%;
    /* clip (not hidden) so horizontal overflow is still cut, but overflow-y
       stays visible. overflow-x:hidden would force overflow-y to compute to
       auto, turning this block into its own vertical scroll container. */
    overflow-x: clip;
  }

  .frame {
    position: relative;
    width: 100%;
    max-width: calc(var(--container-max) * 0.75);
    margin: 0 auto;
    aspect-ratio: 1437 / 630;
    container-type: inline-size;
  }

  .header-inner {
    position: absolute;
    top: 12.86%;
    left: 11.76%;
    right: 6%;
    z-index: 3;
  }

  .eyebrow {
    font-family: var(--font-serif);
    font-weight: 300;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--stand-black);
    margin: 0 0 clamp(8px, 1.5vh, 26px);
  }

  .headline {
    font-family: var(--font-sans);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--stand-black);
    margin: 0;
    max-width: none;
  }

  .biz {
    position: absolute;
    z-index: 2;
    left: var(--cx);
    top: var(--cy);
    width: var(--w);
    height: var(--h);
    transform: translate(-50%, -50%) rotate(var(--rot, 0deg));
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    appearance: none;
  }

  .silhouette,
  .photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: opacity 260ms ease-out;
  }

  /* Photo and silhouette share a uniform 3000×3000 canvas, so they register
     exactly — just cross-fade, no per-item scaling. */
  .photo {
    opacity: 0;
    pointer-events: none;
  }

  .biz:hover .silhouette,
  .biz.active .silhouette {
    opacity: 0;
  }
  .biz:hover .photo,
  .biz.active .photo {
    opacity: 1;
  }

  /* Per-item hover label — positioned beneath the hovered item by JS and shown
     only while it (or, on mobile, the tapped item) is active. Not rotated. */
  .label {
    position: absolute;
    z-index: 10;
    text-align: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms ease-out;
  }

  .label.is-visible {
    opacity: 1;
  }

  .label-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 2.296cqw; /* 33px @1437 */
    line-height: 1.1;
    color: var(--stand-black);
    margin: 0 0 0.8cqw;
  }

  .label-desc {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.113cqw; /* 16px @1437 */
    line-height: 1.3;
    letter-spacing: -0.02em;
    color: var(--stand-black);
    margin: 0;
  }

  @media (max-width: 768px) {
    .find-business {
      padding: 0;
      transition: padding-bottom 260ms ease-out;
    }

    .find-business.has-active { padding-bottom: 188px; }

    /* Mobile: portrait canvas with a compact mobile coordinate set on each item.
       Items are upright (no tilt) and corner-positioned; the label becomes a
       fixed bottom panel on tap. */
    .frame {
      max-width: none;
      aspect-ratio: 375 / 513;
    }

    .header-inner {
      top: 7%;
      left: 10%;
      right: 8%;
    }

    .eyebrow {
      margin: 0 0 8px;
      font-size: 10px;
      line-height: 1.1;
    }

    .headline {
      font-size: 22px;
      line-height: 0.98;
      letter-spacing: 0;
    }

    .biz {
      left: var(--mx);
      top: var(--my);
      width: var(--mw);
      height: var(--mh);
      transform: none;
    }

    .biz:focus-visible {
      outline: 2px solid var(--stand-black);
      outline-offset: 5px;
      filter: drop-shadow(0 0 0.45rem var(--stand-white));
    }

    /* Override the JS-set inline position: pin the label to a bottom panel. */
    .label {
      left: 0 !important;
      top: calc(100% - 16px) !important;
      width: 100vw !important;
      min-height: 188px;
      box-sizing: border-box;
      padding: 26px 38px 28px;
      background: var(--stand-white);
      text-align: left;
    }

    .label-title {
      font-size: 27px;
      line-height: 0.9;
      margin: 0 0 18px;
    }

    .label-desc {
      max-width: 300px;
      font-size: 17px;
      line-height: 1.08;
      letter-spacing: 0;
    }
  }
</style>

---
// FIND YOUR BUSINESS — Figma node 107:744 (1437×1083, redesign 2026-05-26).
// Cream frame with a white panel across the bottom. Eyebrow + headline, a
// horizontal row of 6 product silhouettes, and a shared prompt that defaults to
// "hover over an item / to learn more about our Product Lab." and swaps to the
// hovered item's name + bio. On hover the silhouette becomes the real photo.
// Type scales with the frame (cqw) so it stays proportional below 1437px.

interface Business {
  name: string;
  desc: string;
  svg: string;   // silhouette (default)
  photo: string; // real product image (revealed on hover)
  // bounding box in raw Figma px, relative to the 1437×1083 frame
  sx: number; sy: number; sw: number; sh: number;
  z: number; // stacking order (higher = front)
  // Mobile coords, relative to MOBILE_W × MOBILE_H portrait frame
  mx: number; my: number; mw: number; mh: number;
  // Per-item hover-photo scale. The PNGs have varying internal padding, so
  // each one needs its own factor to fill the silhouette without overshooting.
  photoScale: number;
  // Per-item hover-photo nudges in px (positive Y = down, positive X = right).
  // Default 0; some PNGs have asymmetric padding that needs a tiny shift to align
  // with the silhouette.
  photoOffsetY?: number;
  photoOffsetX?: number;
}

const HERO_W = 1437;
const HERO_H = 1083;
const MOBILE_W = 375;
const MOBILE_H = 513;
const pct = (n: number, base: number) => `${(n / base) * 100}%`;

const DEFAULT_TITLE = 'hover over an item';
const DEFAULT_DESC = 'to learn more about our Product Lab.';

const items: Business[] = [
  { name: 'hats', desc: 'Design custom hats of your own creation.',
    svg: 'STAND_SVG_BlueHat_Silhouette', photo: 'STAND_PNG_BlueHat',
    sx: 90, sy: 291, sw: 263, sh: 263, z: 4,
    mx: 91, my: 117, mw: 163, mh: 100,
    photoScale: 1.600 },
  { name: 'stickers & art', desc: 'Create sticker packs, cards, prints, and custom designs.',
    svg: 'STAND_SVG_YellowSticker_Silhouette', photo: 'STAND_PNG_YellowSticker',
    sx: 301, sy: 470, sw: 220, sh: 220, z: 2,
    mx: -6, my: 198, mw: 124, mh: 123,
    photoScale: 1.315 },
  { name: 'jewelry', desc: 'Make bracelets, charms and accessories with your own style.',
    svg: 'STAND_SVG_GreenBracelet_Silhouette', photo: 'STAND_PNG_GreenBracelet',
    sx: 513, sy: 350, sw: 183, sh: 183, z: 6,
    mx: -2, my: 358, mw: 155, mh: 106,
    photoScale: 1.200, photoOffsetY: 2 },
  { name: 'baked goods', desc: 'Cookies, cupcakes and other treats with your own brand.',
    svg: 'STAND_SVG_RedCupcake_Silhouette', photo: 'STAND_PNG_RedCupcake',
    sx: 672, sy: 416, sw: 227, sh: 227, z: 5,
    mx: 264, my: 108, mw: 88, mh: 150,
    photoScale: 1.600 },
  { name: 'collectibles', desc: 'Create fun collectible products like plushies and slime.',
    svg: 'STAND_SVG_YellowPlushie_Silhouette', photo: 'STAND_PNG_YellowPlushie',
    sx: 890, sy: 329, sw: 230, sh: 230, z: 1,
    mx: 118, my: 231, mw: 125, mh: 116,
    photoScale: 1.085, photoOffsetX: 1 },
  { name: 'clothes & apparel', desc: 'Create hoodies, tees, and other products with your own designs.',
    svg: 'STAND_SVG_PinkHoodie_Silhouette', photo: 'STAND_PNG_PinkHoodie',
    sx: 1084, sy: 384, sw: 236, sh: 236, z: 3,
    mx: 180, my: 293, mw: 176, mh: 179,
    photoScale: 1.065, photoOffsetY: -3, photoOffsetX: 5 },
];
---

<section class="find-business">
  <div class="panel" aria-hidden="true"></div>
  <div class="frame">
    <div class="header-inner">
      <p class="eyebrow">Find Your Business</p>
      <h2 class="headline">Explore business ideas kids can actually imagine building.</h2>
    </div>

    {
      items.map((item, i) => (
        <button
          class="biz"
          type="button"
          data-name={item.name}
          data-desc={item.desc}
          data-num={String(i + 1)}
          aria-label={item.name}
          style={{
            '--x': pct(item.sx, HERO_W),
            '--y': pct(item.sy, HERO_H),
            '--w': pct(item.sw, HERO_W),
            '--h': pct(item.sh, HERO_H),
            '--mx': pct(item.mx, MOBILE_W),
            '--my': pct(item.my, MOBILE_H),
            '--mw': pct(item.mw, MOBILE_W),
            '--mh': pct(item.mh, MOBILE_H),
            '--photo-scale': item.photoScale,
            '--photo-offset-y': `${item.photoOffsetY ?? 0}px`,
            '--photo-offset-x': `${item.photoOffsetX ?? 0}px`,
            zIndex: item.z,
          }}
        >
          <img class="silhouette" src={`/brand/${item.svg}.svg`} alt={item.name} />
          <img class="photo" src={`/brand/${item.photo}.webp`} alt="" aria-hidden="true" loading="lazy" />
          <span class="biz-label"><strong>{item.name}</strong><em>{item.desc}</em></span>
        </button>
      ))
    }

    <div class="prompt" data-default-title={DEFAULT_TITLE} data-default-desc={DEFAULT_DESC}>
      <h3 class="prompt-title">{DEFAULT_TITLE}</h3>
      <p class="prompt-desc">{DEFAULT_DESC}</p>
    </div>
  </div>
</section>

<script>
  const section = document.querySelector('.find-business');
  if (section) {
    const prompt = section.querySelector('.prompt');
    const titleEl = prompt?.querySelector('.prompt-title');
    const descEl = prompt?.querySelector('.prompt-desc');
    const defTitle = prompt?.getAttribute('data-default-title') ?? '';
    const defDesc = prompt?.getAttribute('data-default-desc') ?? '';
    const isDesktop = () => window.matchMedia('(min-width: 769px)').matches;
    const cards = section.querySelectorAll('.biz');

    cards.forEach((card) => {
      card.addEventListener('pointerenter', () => {
        if (!isDesktop() || !titleEl || !descEl) return;
        card.classList.add('active');
        titleEl.textContent = card.getAttribute('data-name');
        descEl.textContent = card.getAttribute('data-desc');
      });
      card.addEventListener('pointerleave', () => {
        if (!isDesktop() || !titleEl || !descEl) return;
        card.classList.remove('active');
        titleEl.textContent = defTitle;
        descEl.textContent = defDesc;
      });
      // Mobile: tap a card to reveal the product photo AND update the prompt
      // (one open at a time). Same active class as desktop hover state.
      card.addEventListener('click', () => {
        if (isDesktop() || !titleEl || !descEl) return;
        const wasActive = card.classList.contains('active');
        cards.forEach((c) => c.classList.remove('active'));
        if (!wasActive) {
          section.classList.add('has-active');
          card.classList.add('active');
          titleEl.textContent = card.getAttribute('data-name');
          descEl.textContent = card.getAttribute('data-desc');
        } else {
          section.classList.remove('has-active');
          titleEl.textContent = defTitle;
          descEl.textContent = defDesc;
        }
      });
    });
  }
</script>

<style>
  .find-business {
    position: relative;
    background: var(--stand-cream);
    width: 100%;
    /* clip (not hidden) so horizontal overflow is still cut, but overflow-y
       stays visible. overflow-x:hidden would force overflow-y to compute to
       auto, turning this block into its own vertical scroll container. */
    overflow-x: clip;
  }

  .frame {
    position: relative;
    width: 100%;
    max-width: calc(var(--container-max) * 0.75);
    margin: 0 auto;
    aspect-ratio: 1437 / 1083;
    container-type: inline-size;
  }

  /* White panel across the bottom third (Figma rect 453:137).
     Lives on the section so it spans the full viewport width — the .frame is
     centered and capped, but the panel must reach edge-to-edge. */
  .panel {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 30%;
    background: var(--stand-white);
    z-index: 0;
  }

  .header-inner {
    position: absolute;
    top: 7%;
    left: 6.5%;
    right: 6.5%;
    z-index: 3;
  }

  .eyebrow {
    font-family: var(--font-serif);
    font-weight: 300;
    line-height: 1.18;
    letter-spacing: -0.04em;
    color: var(--stand-black);
    margin: 0 0 clamp(12px, 2.25vh, 45px); /* matches About */
  }

  .headline {
    font-family: var(--font-sans);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.022em;
    color: var(--stand-black);
    margin: 0;
    max-width: none;
  }

  .biz {
    position: absolute;
    z-index: 2;
    left: var(--x);
    top: var(--y);
    width: var(--w);
    height: var(--h);
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    appearance: none;
  }

  .silhouette,
  .photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: opacity 260ms ease-out;
  }

  /* Photos are square PNGs with padding; scale up to match the tight silhouette.
     Each item passes its own --photo-scale because the PNGs have varying padding. */
  .photo {
    transform: translate(var(--photo-offset-x, 0px), var(--photo-offset-y, 0px)) scale(var(--photo-scale, 1.115));
    opacity: 0;
    pointer-events: none;
  }

  .biz:hover .silhouette,
  .biz.active .silhouette {
    opacity: 0;
  }
  .biz:hover .photo,
  .biz.active .photo {
    opacity: 1;
  }

  /* Per-item label is desktop-hidden (shown only in the mobile list). */
  .biz-label {
    display: none;
  }

  /* Shared prompt on the white panel. */
  .prompt {
    position: absolute;
    left: 6%;
    right: 6%;
    top: 80%;
    text-align: center;
    z-index: 2;
  }

  .prompt-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 2.296cqw; /* 33px @1437 */
    line-height: 1.1;
    color: var(--stand-black);
    margin: 0 0 0.8cqw;
  }

  .prompt-desc {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.113cqw; /* 16px @1437 */
    line-height: 1.3;
    letter-spacing: -0.02em;
    color: var(--stand-black);
    margin: 0;
  }

  @media (max-width: 768px) {
    .find-business {
      padding: 0;
      transition: padding-bottom 260ms ease-out;
    }

    .find-business.has-active { padding-bottom: 188px; }

    /* Mobile: same frame-based layout as desktop, but portrait canvas with
       a compact mobile coordinate set on each item. Header sits top-left,
       white panel sits below the icon cluster, prompt updates on tap. */
    .frame {
      max-width: none;
      aspect-ratio: 375 / 513;
    }

    .panel { display: none; }

    .header-inner {
      top: 7%;
      left: 10%;
      right: 8%;
    }

    .eyebrow {
      margin: 0 0 8px;
      font-size: 10px;
      line-height: 1.1;
    }

    .headline {
      font-size: 22px;
      line-height: 0.98;
      letter-spacing: 0;
    }

    .biz {
      left: var(--mx);
      top: var(--my);
      width: var(--mw);
      height: var(--mh);
    }

    .biz:focus-visible {
      outline: 2px solid var(--stand-black);
      outline-offset: 5px;
      filter: drop-shadow(0 0 0.45rem var(--stand-white));
    }

    .biz.active .photo {
      transform: translate(var(--photo-offset-x, 0px), var(--photo-offset-y, 0px)) scale(calc(var(--photo-scale, 1.115) * 1.25));
    }

    .biz-label { display: none; }

    .prompt {
      left: 0;
      right: auto;
      top: calc(100% - 16px);
      width: 100vw;
      min-height: 188px;
      box-sizing: border-box;
      padding: 26px 38px 28px;
      background: var(--stand-white);
      text-align: left;
      opacity: 0;
      pointer-events: none;
      transition: opacity 220ms ease-out;
    }

    .find-business.has-active .prompt {
      opacity: 1;
    }

    .prompt-title {
      font-size: 27px;
      line-height: 0.9;
      margin: 0 0 18px;
    }

    .prompt-desc {
      max-width: 300px;
      font-size: 17px;
      line-height: 1.08;
      letter-spacing: 0;
    }
  }
</style>

---
// Tagline strip — Figma nodes 201:2483 (top) / 201:2545 (bottom)
// Per Faye: "text on rotation. itll say one phrase, then the other, then
// other on loop. no transition motion needed between them."
// Single phrase visible at a time, swapped on a timer with no animation.

interface Props {
  items?: string[];
  height?: number;
  /** Seconds each phrase is visible before swapping to the next. */
  interval?: number;
  /** Unique id needed if more than one Marquee renders on the page. */
  id?: string;
}

const {
  items = ['Dream. Build. Grow.', 'What will you build?'],
  height = 123,
  interval = 2.5,
  id = `marquee-${Math.random().toString(36).slice(2, 8)}`,
} = Astro.props;
---

<div class="marquee" style={{ height: `${height}px` }} id={id} aria-hidden="true">
  {
    items.map((text, i) => (
      <span class="phrase" data-active={i === 0 ? 'true' : 'false'}>
        {text}
      </span>
    ))
  }
</div>

<script define:vars={{ id, interval }}>
  const wrap = document.getElementById(id);
  if (wrap) {
    const phrases = wrap.querySelectorAll('.phrase');
    if (phrases.length > 1) {
      let i = 0;
      setInterval(() => {
        phrases[i].dataset.active = 'false';
        i = (i + 1) % phrases.length;
        phrases[i].dataset.active = 'true';
      }, interval * 1000);
    }
  }
</script>

<style>
  .marquee {
    background: var(--stand-red);
    color: var(--stand-postit);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    overflow: hidden;
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: 52px;
    line-height: 1;
    letter-spacing: -1px;
    text-align: center;
    position: relative;
  }

  .phrase {
    position: absolute;
    display: none;
    padding: 0 20px;
  }

  .phrase[data-active='true'] {
    display: inline-block;
  }

  @media (max-width: 768px) {
    .marquee {
      font-size: 28px;
    }
  }
</style>

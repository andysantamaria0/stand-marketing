---
// Product-silhouette ticker — Figma node 201:2545 (CAROUSEL), 1437x123.
// Green strip with a continuously scrolling row of recolored product
// silhouettes. Each icon reuses the existing /brand silhouette SVG as a CSS
// mask, filled with a brand token (tokens.css now matches the Figma palette).

interface Icon {
  svg: string;
  color: string;
  rotate?: number;
}

const icons: Icon[] = [
  { svg: 'STAND_SVG_PinkHoodie_Silhouette', color: 'var(--stand-pink)', rotate: 12.79 },
  { svg: 'STAND_SVG_RedCupcake_Silhouette', color: 'var(--stand-red)' },
  { svg: 'STAND_SVG_GreenBracelet_Silhouette', color: 'var(--stand-cream)' },
  // Asset names are counterintuitive: _YellowPlushie_ is the star shape and
  // _YellowSticker_ is the rounded shape (verified by render). Mapped to match
  // the Figma carousel: star at post-it yellow, rounded at golden/mustard.
  { svg: 'STAND_SVG_YellowPlushie_Silhouette', color: 'var(--stand-postit)' },
  { svg: 'STAND_SVG_BlueHat_Silhouette', color: 'var(--stand-blue)', rotate: -5.36 },
  { svg: 'STAND_SVG_YellowSticker_Silhouette', color: 'var(--stand-mustard)' },
];

// Faster scroll (~2x) and a big trailing gap per group so the icon set "ends"
// with green space between loops instead of tiling into a dense stream.
const duration = 20;
const groups = [0, 1, 2];
---

<div class="icon-ticker" aria-hidden="true">
  <div class="track" style={{ animationDuration: `${duration}s` }}>
    {
      groups.map(() => (
        <div class="group">
          {icons.map((ic) => (
            <span
              class="icon"
              style={{
                '--icon-color': ic.color,
                '--icon-mask': `url('/brand/${ic.svg}.svg')`,
                '--icon-rot': `${ic.rotate ?? 0}deg`,
              }}
            />
          ))}
        </div>
      ))
    }
  </div>
</div>

<style>
  .icon-ticker {
    background: var(--stand-green);
    height: 96px;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .track {
    display: flex;
    flex-shrink: 0;
    animation: icon-scroll linear infinite;
  }

  .group {
    display: flex;
    align-items: center;
    gap: 22px;
    /* small trailing gap matches the inter-icon gap so the loop has no seam */
    padding-right: 22px;
    flex-shrink: 0;
  }

  .icon {
    width: 50px;
    height: 50px;
    flex-shrink: 0;
    background-color: var(--icon-color);
    transform: rotate(var(--icon-rot));
    mask-image: var(--icon-mask);
    mask-repeat: no-repeat;
    mask-position: center;
    mask-size: contain;
    -webkit-mask-image: var(--icon-mask);
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-position: center;
    -webkit-mask-size: contain;
  }

  /* Track is 3 identical groups; shifting by one group-width loops seamlessly. */
  @keyframes icon-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-33.333%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .track { animation: none; }
  }

  @media (max-width: 768px) {
    .icon-ticker { height: 64px; }
    .icon { width: 38px; height: 38px; }
    .group { gap: 16px; padding-right: 16px; }
  }
</style>

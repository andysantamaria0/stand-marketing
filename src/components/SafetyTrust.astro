---
// SAFETY AND TRUST — Figma node 118:330 (1437×1137)
// Post-it yellow bg with two large skewed white cards (left at -2.59°, right at +2.13°).
// Cream Mug rotated -9.09° at top-left of section. "For Real." script positioned in
// the lower band as a vector group.
---

<section class="safety">
  <div class="cards-stack">
    <img class="prop-mug" src="/brand/STAND_PNG_CreamMug.webp" alt="" loading="lazy" aria-hidden="true" />

    <div class="cards">
    <article class="note note-left">
      <h3>safety &amp; trust</h3>
      <p>
        STAND is built with families in mind. Parent approval, age-appropriate tools, guided
        business categories, and clear oversight are core to how the platform works. Kids get
        to create and learn, while parents stay connected to the experience.
      </p>
    </article>

    <article class="note note-right">
      <h3>learn by doing</h3>
      <p>
        Kids do not just watch lessons about entrepreneurship. They make decisions, test ideas,
        create products, price what they sell, talk to customers, and learn from what happens.
      </p>
      <p>That is how real-world skills stick.</p>
    </article>
    </div>
  </div>

  <img class="for-real" src="/brand/STAND_ForReal.svg" alt="For Real." />
</section>

<style>
  .safety {
    background: var(--stand-postit);
    width: 100%;
    overflow: hidden;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(8px, 1.5vh, 20px);
    padding: clamp(60px, 8vh, 100px) 0 0;
  }

  /* Holds the mug + cards; the top padding reserves the mug's peek above the
     cards so the section can be vertically centered without the mug clipping. */
  .cards-stack {
    position: relative;
    width: 100%;
    max-width: calc(var(--container-max) * 0.75);
    /* Top offset lifts the mug clear of the card title (it overlaps the card's
       white top edge, not the "safety & trust" text). */
    padding-top: clamp(110px, 16vh, 160px);
  }

  .prop-mug {
    position: absolute;
    left: 30%;
    top: 0;
    width: 16.15%;
    max-width: 240px;
    aspect-ratio: 1;
    transform: rotate(-9.09deg);
    z-index: 3;
  }

  .cards {
    position: relative;
    z-index: 2;
    max-width: calc(var(--container-max) * 0.75);
    margin: 0 auto;
    padding: 0 45px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    align-items: start;
  }

  .note {
    background: var(--stand-white);
    border: 3px solid var(--stand-black);
    box-shadow: 5px 7px 0 var(--stand-black);
    padding: 42px 32px;
    width: 100%;
    max-width: 455px;
    display: flex;
    flex-direction: column;
    gap: 26px;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .note-left {
    transform: rotate(-2.59deg);
    justify-self: end;
  }

  .note-right {
    transform: rotate(2.13deg);
    margin-top: -80px;
    justify-self: start;
  }

  .note h3 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(17px, 1.722vw, 25px);
    line-height: 1.2;
    color: var(--stand-black);
    margin: 0;
  }

  .note p {
    font-family: var(--font-sans);
    font-weight: 400;
    /* Anchored to the ExtraBio .copy p paragraph (14px) so both body
       paragraphs read at one size across the site. */
    font-size: 14px;
    line-height: 1.2;
    letter-spacing: -0.24px;
    color: var(--stand-black);
    margin: 0;
  }

  .for-real {
    display: block;
    width: 70%;
    max-width: 800px;
    height: auto;
    /* Pull the script up into the cards' lower band — the right card's bottom
       edge sits well above the section's bottom, so without a negative pull
       there's a big empty yellow band before "For Real." starts. */
    margin: -8vh 4% 0 auto;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 1024px) {
    .note p { font-size: 16px; }
    .note h3 { font-size: 30px; }
  }

  @media (max-width: 768px) {
    .safety {
      padding: 40px 0 48px;
      min-height: 0;
      display: block;
    }
    .cards-stack {
      padding-top: 0;
    }
    .prop-mug {
      /* On mobile, take the mug OUT of absolute positioning and let it
         flow above the first card. Absolute-positioning it into the
         heading's band (top: -32px, etc.) was fragile — clearance depended
         on exact viewport width + the webp's internal transparent padding,
         so it covered the "safety & trust" heading on some phones. In flow
         with a small negative margin-bottom, the mug rests on the card's
         top-left corner (white border region) and the heading — which sits
         a full card-padding (28px) below the card's top edge — is always
         clear, at any phone width. */
      position: relative;
      z-index: 3;
      width: 30%;
      max-width: 150px;
      margin: 0 0 -52px 6%;
      left: auto;
      top: auto;
    }
    .cards {
      grid-template-columns: 1fr;
      gap: 28px;
      margin-top: 0;
      padding: 0 20px;
    }
    .note {
      padding: 28px 22px;
      gap: 18px;
      max-width: none;
    }
    .note-right {
      margin-top: 0;
    }
    .note h3 {
      font-size: 26px;
    }
    .note p {
      font-size: 16px;
    }
    .for-real {
      width: 95%;
      max-width: 95%;
      max-height: none;
      margin-top: 32px;
    }
  }
</style>
